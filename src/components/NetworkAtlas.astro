---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const romanNumerals = ['i', 'ii', 'iii', 'iv', 'v'];
---

<div class="plate" id="plate-atlas">
  <header class="plate-head">
    <span class="plate-num">Plate I</span>
    <h3 class="plate-title">Character co-presence</h3>
  </header>

  <div class="view-line" id="atlas-controls">
    <span class="view-label">View</span>
    <button class="view-btn active" data-mode="overview">Overview</button>
    <span class="view-sep">·</span>
    <button class="view-btn" data-mode="slothrop">Slothrop</button>
    <span class="view-sep">·</span>
    <button class="view-btn" data-mode="communities">Communities</button>
    <span class="view-sep">·</span>
    <button class="view-btn" data-mode="full">Full</button>
  </div>

  <div class="atlas-layout">
    <div id="network-atlas" class="atlas-canvas" data-base={base}></div>
    <aside class="atlas-rail" id="atlas-rail">
      <div id="atlas-note" class="atlas-note"></div>
      <div class="atlas-key" id="atlas-key">
        <div class="key-head">Community Index</div>
      </div>
    </aside>
  </div>
</div>

<script define:vars={{ romanNumerals }}>
  window.__atlasRomanNumerals = romanNumerals;
</script>

<script>
  import * as d3 from 'd3';

  const canvas = document.getElementById('network-atlas')!;
  const noteEl = document.getElementById('atlas-note')!;
  const keyEl = document.getElementById('atlas-key')!;
  const base = canvas.dataset.base || '';
  const romanNumerals: string[] = (window as any).__atlasRomanNumerals || ['i','ii','iii','iv','v'];

  const W = 960, H = 720, PAD = 50;

  type Mode = 'overview' | 'slothrop' | 'communities' | 'full';
  let mode: Mode = 'overview';
  let selectedCommunity: number | null = null;
  let locked: string | null = null;

  const svg = d3.select(canvas)
    .append('svg')
    .attr('viewBox', `0 0 ${W} ${H}`)
    .attr('preserveAspectRatio', 'xMidYMid meet')
    .attr('role', 'img')
    .attr('aria-label', 'Interactive character co-presence network: 130 named characters across five communities');

  svg.append('rect')
    .attr('width', W).attr('height', H)
    .attr('fill', 'var(--color-surface)')
    .attr('rx', 2);

  const gHulls = svg.append('g').attr('class', 'hulls');
  const gEdges = svg.append('g').attr('class', 'edges');
  const gNodes = svg.append('g').attr('class', 'nodes');
  const gLabels = svg.append('g').attr('class', 'labels');

  Promise.all([
    fetch(`${base}/data/step_2d/master_network_layout_nodes_public.csv`).then(r => r.text()),
    fetch(`${base}/data/step_2d/master_network_layout_edges_public.csv`).then(r => r.text()),
  ]).then(([nodesText, edgesText]) => {
    const nodes = d3.csvParse(nodesText, d => ({
      id: d.id!, short_name: d.short_name!,
      x: +d.x!, y: +d.y!,
      community_id: +d.community_id!, community_label: d.community_label!,
      community_colour: d.community_colour!,
      weighted_degree: +d.weighted_degree!, degree: +d.degree!,
      betweenness_centrality: +d.betweenness_centrality!,
      episode_count: +d.episode_count!, label_tier: +d.label_tier!,
      display_radius: +d.display_radius!,
    }));

    const edges = d3.csvParse(edgesText, d => ({
      source: d.source!, target: d.target!,
      weight: +d.weight!, shared_episode_count: +d.shared_episode_count!,
      association_strength: +d.association_strength!, display_width: +d.display_width!,
    }));

    const nodeMap = new Map(nodes.map(n => [n.id, n]));

    const xExt = d3.extent(nodes, d => d.x) as [number, number];
    const yExt = d3.extent(nodes, d => d.y) as [number, number];
    const xS = d3.scaleLinear().domain([xExt[0] - 0.4, xExt[1] + 0.4]).range([PAD, W - PAD]);
    const yS = d3.scaleLinear().domain([yExt[0] - 0.4, yExt[1] + 0.4]).range([H - PAD, PAD]);
    const rS = d3.scaleLinear().domain([0, 1]).range([2.5, 14]);

    const adj = new Map<string, Set<string>>();
    for (const n of nodes) adj.set(n.id, new Set());
    for (const e of edges) {
      adj.get(e.source)?.add(e.target);
      adj.get(e.target)?.add(e.source);
    }

    const communities = [...new Map(nodes.map(n => [
      n.community_id, { id: n.community_id, label: n.community_label, colour: n.community_colour }
    ])).values()].sort((a, b) => a.id - b.id);

    const communityNodes = new Map<number, typeof nodes>();
    for (const c of communities) communityNodes.set(c.id, nodes.filter(n => n.community_id === c.id));

    // --- Hulls ---
    function paddedHull(pts: [number, number][], pad: number): [number, number][] | null {
      if (pts.length < 3) return null;
      const hull = d3.polygonHull(pts);
      if (!hull || hull.length < 3) return null;
      const cx = d3.mean(hull, p => p[0])!;
      const cy = d3.mean(hull, p => p[1])!;
      return hull.map(([px, py]) => {
        const dx = px - cx, dy = py - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const s = (dist + pad) / dist;
        return [cx + dx * s, cy + dy * s] as [number, number];
      });
    }

    const hullLine = d3.line<[number, number]>()
      .curve(d3.curveCatmullRomClosed.alpha(0.5))
      .x(d => d[0]).y(d => d[1]);

    const hullPaths = new Map<number, string>();
    for (const c of communities) {
      const pts: [number, number][] = communityNodes.get(c.id)!.map(n => [xS(n.x), yS(n.y)]);
      const hull = paddedHull(pts, 30);
      if (hull) hullPaths.set(c.id, hullLine(hull)!);
    }

    const hulls = gHulls.selectAll('path')
      .data(communities.filter(c => hullPaths.has(c.id)))
      .join('path')
      .attr('d', d => hullPaths.get(d.id)!)
      .attr('fill', d => d.colour)
      .attr('fill-opacity', 0.04)
      .attr('stroke', d => d.colour)
      .attr('stroke-opacity', 0.06)
      .attr('stroke-width', 1);

    // --- Edges ---
    const edgeLines = gEdges.selectAll('line')
      .data(edges).join('line')
      .attr('x1', d => xS(nodeMap.get(d.source)!.x))
      .attr('y1', d => yS(nodeMap.get(d.source)!.y))
      .attr('x2', d => xS(nodeMap.get(d.target)!.x))
      .attr('y2', d => yS(nodeMap.get(d.target)!.y))
      .attr('stroke', 'var(--color-text-dim)')
      .attr('stroke-width', d => 0.4 + d.display_width * 1.5);

    // --- Nodes ---
    const circles = gNodes.selectAll('circle')
      .data(nodes).join('circle')
      .attr('cx', d => xS(d.x))
      .attr('cy', d => yS(d.y))
      .attr('r', d => rS(d.display_radius))
      .attr('fill', d => d.community_colour)
      .attr('fill-opacity', 0.75);

    // --- Labels ---
    const labels = gLabels.selectAll('text')
      .data(nodes).join('text')
      .attr('x', d => xS(d.x) + rS(d.display_radius) + 4)
      .attr('y', d => yS(d.y) + 1)
      .text(d => d.short_name)
      .attr('fill', d => d.label_tier === 1 ? 'var(--color-text)' : 'var(--color-text-dim)')
      .attr('font-family', 'var(--font-mono)')
      .attr('font-size', d => d.label_tier === 1 ? '11px' : '8.5px')
      .attr('dominant-baseline', 'middle')
      .attr('class', d => `atlas-label tier-${d.label_tier}`)
      .attr('pointer-events', 'none');

    // --- Hit areas ---
    const hitAreas = gNodes.selectAll('.hit')
      .data(nodes).join('circle')
      .attr('class', 'hit')
      .attr('cx', d => xS(d.x))
      .attr('cy', d => yS(d.y))
      .attr('r', d => Math.max(rS(d.display_radius), 8) + 4)
      .attr('fill', 'transparent')
      .attr('cursor', 'pointer');

    // --- Note functions ---
    function showNote(node: typeof nodes[0] | null, annotation?: string) {
      if (!node) { updateModeNote(); return; }
      noteEl.innerHTML = `
        <p class="note-name">${node.short_name}</p>
        <p class="note-community" style="color:${node.community_colour}">${node.community_label}</p>
        <p class="note-stats">${node.episode_count} episodes · ${node.degree} connections</p>
        <p class="note-stats">betweenness: ${node.betweenness_centrality.toFixed(3)}</p>
        ${annotation ? `<p class="note-body">${annotation}</p>` : ''}
      `;
      noteEl.style.opacity = '1';
    }

    function updateModeNote() {
      switch (mode) {
        case 'overview':
          noteEl.innerHTML = `
            <p class="note-title">Co-presence Atlas</p>
            <p class="note-stats">130 characters · 1,959 edges · 5 communities</p>
            <p class="note-body">Strongest connections and community regions. Node size reflects weighted degree. Hover or click any character to explore.</p>
          `;
          break;
        case 'slothrop': {
          const s = nodeMap.get('Tyrone Slothrop')!;
          noteEl.innerHTML = `
            <p class="note-name">Slothrop</p>
            <p class="note-community" style="color:${s.community_colour}">${s.community_label}</p>
            <p class="note-stats">${s.episode_count} episodes · ${s.degree} connections</p>
            <p class="note-stats">betweenness: ${s.betweenness_centrality.toFixed(3)}</p>
            <p class="note-body">Bridges all five communities. Highest betweenness centrality in the network. Edges coloured by neighbour community.</p>
          `;
          break;
        }
        case 'communities': {
          if (selectedCommunity !== null) {
            const c = communities.find(c => c.id === selectedCommunity)!;
            const members = communityNodes.get(selectedCommunity)!;
            const top5 = [...members].sort((a, b) => b.weighted_degree - a.weighted_degree).slice(0, 5);
            noteEl.innerHTML = `
              <p class="note-name" style="color:${c.colour}">${c.label}</p>
              <p class="note-stats">${members.length} characters</p>
              <p class="note-body">Anchored by ${top5.map(n => n.short_name).join(', ')}.</p>
            `;
          } else {
            noteEl.innerHTML = `
              <p class="note-title">Communities</p>
              <p class="note-body">Select a community from the index below to explore its internal structure.</p>
            `;
          }
          break;
        }
        case 'full':
          noteEl.innerHTML = `
            <p class="note-title">Complete Network</p>
            <p class="note-stats">130 characters · 1,959 edges</p>
            <p class="note-body">All connections visible. Association strength determines edge weight. All labels shown.</p>
          `;
          break;
      }
      noteEl.style.opacity = '1';
    }

    // --- Mode rendering ---
    const DUR = 350;

    function applyOverview() {
      const t = svg.transition().duration(DUR);
      hulls.transition(t).attr('fill-opacity', 0.04).attr('stroke-opacity', 0.06);
      edgeLines.transition(t)
        .attr('stroke', 'var(--color-text-dim)')
        .attr('stroke-opacity', (d: any) => d.display_width >= 0.15 ? 0.04 + d.display_width * 0.2 : 0);
      circles.transition(t).attr('fill-opacity', 0.75).attr('r', (d: any) => rS(d.display_radius));
      labels.transition(t).attr('opacity', (d: any) => d.label_tier === 1 ? 1 : 0);
    }

    function applySlothrop() {
      const t = svg.transition().duration(DUR);
      const sid = 'Tyrone Slothrop';
      const neighbours = adj.get(sid) || new Set();
      hulls.transition(t).attr('fill-opacity', 0.02).attr('stroke-opacity', 0.03);
      edgeLines.transition(t)
        .attr('stroke', (d: any) => {
          if (d.source === sid) return nodeMap.get(d.target)!.community_colour;
          if (d.target === sid) return nodeMap.get(d.source)!.community_colour;
          return 'var(--color-text-dim)';
        })
        .attr('stroke-opacity', (d: any) =>
          d.source === sid || d.target === sid ? 0.3 + d.display_width * 0.35 : 0.01
        );
      circles.transition(t)
        .attr('fill-opacity', (d: any) =>
          d.id === sid ? 1 : neighbours.has(d.id) ? 0.7 : 0.08
        )
        .attr('r', (d: any) =>
          d.id === sid ? rS(d.display_radius) + 3 : rS(d.display_radius)
        );
      labels.transition(t).attr('opacity', (d: any) =>
        d.id === sid ? 1 : neighbours.has(d.id) && d.label_tier <= 2 ? 0.9 : 0
      );
    }

    function applyCommunity(cid: number) {
      const t = svg.transition().duration(DUR);
      const cIds = new Set(communityNodes.get(cid)!.map(n => n.id));
      hulls.transition(t)
        .attr('fill-opacity', (d: any) => d.id === cid ? 0.08 : 0.015)
        .attr('stroke-opacity', (d: any) => d.id === cid ? 0.14 : 0.02);
      edgeLines.transition(t)
        .attr('stroke', (d: any) =>
          cIds.has(d.source) && cIds.has(d.target)
            ? communities.find(c => c.id === cid)!.colour
            : 'var(--color-text-dim)'
        )
        .attr('stroke-opacity', (d: any) =>
          cIds.has(d.source) && cIds.has(d.target) ? 0.15 + d.display_width * 0.3 : 0.01
        );
      circles.transition(t)
        .attr('fill-opacity', (d: any) => cIds.has(d.id) ? 0.85 : 0.06);
      labels.transition(t).attr('opacity', (d: any) =>
        cIds.has(d.id) ? (d.label_tier <= 2 ? 1 : 0.7) : 0
      );
    }

    function applyFull() {
      const t = svg.transition().duration(DUR);
      hulls.transition(t).attr('fill-opacity', 0.02).attr('stroke-opacity', 0.04);
      edgeLines.transition(t)
        .attr('stroke', 'var(--color-text-dim)')
        .attr('stroke-opacity', (d: any) => 0.02 + d.display_width * 0.12);
      circles.transition(t).attr('fill-opacity', 0.7).attr('r', (d: any) => rS(d.display_radius));
      labels.transition(t).attr('opacity', (d: any) =>
        d.label_tier === 1 ? 1 : d.label_tier === 2 ? 0.7 : 0.45
      );
    }

    function setMode(m: Mode) {
      mode = m;
      locked = null;
      document.querySelectorAll('#atlas-controls .view-btn').forEach(b =>
        b.classList.toggle('active', (b as HTMLElement).dataset.mode === m)
      );
      switch (m) {
        case 'overview': applyOverview(); break;
        case 'slothrop': applySlothrop(); break;
        case 'communities':
          if (selectedCommunity !== null) applyCommunity(selectedCommunity);
          else { selectedCommunity = 1; applyCommunity(1); updateKeyActive(); }
          break;
        case 'full': applyFull(); break;
      }
      updateModeNote();
    }

    // --- Highlight on hover/click ---
    function highlightNode(id: string | null) {
      if (!id) { setMode(mode); return; }
      const neighbours = adj.get(id) || new Set();
      const t = svg.transition().duration(200);
      circles.transition(t).attr('fill-opacity', (d: any) =>
        d.id === id ? 1 : neighbours.has(d.id) ? 0.65 : 0.06
      );
      edgeLines.transition(t).attr('stroke-opacity', (d: any) =>
        d.source === id || d.target === id ? 0.4 : 0.01
      );
      labels.transition(t).attr('opacity', (d: any) => {
        if (d.id === id) return 1;
        if (neighbours.has(d.id) && d.label_tier <= 2) return 1;
        return 0;
      });
      hulls.transition(t).attr('fill-opacity', 0.015).attr('stroke-opacity', 0.02);
      showNote(nodeMap.get(id)!);
    }

    // --- Controls ---
    document.querySelectorAll('#atlas-controls .view-btn').forEach(btn => {
      btn.addEventListener('click', () => setMode((btn as HTMLElement).dataset.mode as Mode));
    });

    // --- Community key ---
    function updateKeyActive() {
      keyEl.querySelectorAll('.key-row').forEach(r => {
        const cid = +(r as HTMLElement).dataset.cid!;
        r.classList.toggle('active', cid === selectedCommunity);
      });
    }

    for (const c of communities) {
      const count = communityNodes.get(c.id)!.length;
      const row = document.createElement('div');
      row.className = 'key-row';
      row.dataset.cid = String(c.id);
      const ri = romanNumerals[c.id - 1] || String(c.id);
      row.innerHTML = `
        <span class="key-tick" style="background:${c.colour}"></span>
        <span class="key-num">${ri}.</span>
        <span class="key-label">${c.label}</span>
        <span class="key-count">${count}</span>
      `;
      row.addEventListener('click', () => {
        selectedCommunity = c.id;
        updateKeyActive();
        if (mode === 'communities') { applyCommunity(c.id); updateModeNote(); }
        else setMode('communities');
      });
      keyEl.appendChild(row);
    }

    // --- Interaction ---
    hitAreas
      .on('mouseenter', function(_event: any, d: any) {
        if (!locked) highlightNode(d.id);
      })
      .on('mouseleave', function() {
        if (!locked) { setMode(mode); }
      })
      .on('click', function(event: any, d: any) {
        event.stopPropagation();
        if (locked === d.id) { locked = null; setMode(mode); }
        else { locked = d.id; highlightNode(d.id); }
      });

    svg.on('click', () => {
      if (locked) { locked = null; setMode(mode); }
    });

    // --- Cross-component ---
    window.addEventListener('atlas-highlight-community', (e: any) => {
      selectedCommunity = e.detail;
      updateKeyActive();
      setMode('communities');
    });

    window.dispatchEvent(new CustomEvent('atlas-ready', {
      detail: {
        highlightCharacter: (id: string | null) => { locked = id; highlightNode(id); },
        highlightCommunity: (cid: number) => { selectedCommunity = cid; updateKeyActive(); setMode('communities'); },
        setMode,
      }
    }));

    // --- Initial ---
    setMode('overview');
  });
</script>

<style>
  .plate-head {
    margin-bottom: var(--space-sm);
  }

  .plate-num {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .plate-title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    margin-top: 0.2rem;
  }

  /* --- View line --- */
  .view-line {
    display: flex;
    align-items: baseline;
    gap: 0;
    margin-bottom: var(--space-md);
  }

  .view-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-dim);
    margin-right: 1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .view-sep {
    color: var(--color-border);
    margin: 0 0.6rem;
    user-select: none;
  }

  .view-btn {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-dim);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
  }

  .view-btn:hover {
    color: var(--color-text-secondary);
  }

  .view-btn.active {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--color-accent);
  }

  /* --- Atlas layout --- */
  .atlas-layout {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .atlas-canvas {
    flex: 1;
    min-width: 0;
    border: 1px solid var(--color-border-subtle);
    border-radius: 2px;
    background: var(--color-surface);
  }

  .atlas-canvas :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  .atlas-canvas :global(.nodes circle.hit) {
    cursor: pointer;
  }

  .atlas-canvas :global(.atlas-label) {
    pointer-events: none;
    user-select: none;
  }

  /* --- Rail --- */
  .atlas-rail {
    width: 12rem;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding-top: 0.25rem;
  }

  .atlas-note {
    opacity: 0;
    transition: opacity 0.25s;
    min-height: 6rem;
  }

  .atlas-note :global(.note-title) {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.3;
  }

  .atlas-note :global(.note-name) {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-accent);
    line-height: 1.2;
  }

  .atlas-note :global(.note-community) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-top: 0.35rem;
  }

  .atlas-note :global(.note-stats) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-dim);
    margin-top: 0.15rem;
    line-height: 1.5;
  }

  .atlas-note :global(.note-body) {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-dim);
    line-height: 1.65;
    margin-top: 0.6rem;
  }

  /* --- Community key --- */
  .atlas-key {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
  }

  .atlas-key :global(.key-head) {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-sm);
  }

  .atlas-key :global(.key-row) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
    cursor: pointer;
    transition: color 0.15s;
  }

  .atlas-key :global(.key-row:hover .key-label) {
    color: var(--color-text);
  }

  .atlas-key :global(.key-row.active .key-label) {
    color: var(--color-text);
  }

  .atlas-key :global(.key-row.active .key-num) {
    color: var(--color-accent);
  }

  .atlas-key :global(.key-tick) {
    width: 3px;
    height: 1.1rem;
    border-radius: 1px;
    flex-shrink: 0;
  }

  .atlas-key :global(.key-num) {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-text-dim);
    min-width: 1.5rem;
    transition: color 0.15s;
  }

  .atlas-key :global(.key-label) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    flex: 1;
    transition: color 0.15s;
  }

  .atlas-key :global(.key-count) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-dim);
  }

