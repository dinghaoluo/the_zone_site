---
import unifiedData from "../data/phase_3a_unified_episode_data_public.json";

const PLOTLINE_MAP: Record<string, { label: string; key: string; cssVar: string }> = {
  P01: { label: "Slothrop", key: "P01_slothrop_rocket_quest", cssVar: "--strand-slothrop" },
  P02: { label: "Blicero", key: "P02_blicero_katje_gottfried_triad", cssVar: "--strand-blicero" },
  P03: { label: "Enzian", key: "P03_enzian_schwarzkommando", cssVar: "--strand-enzian" },
  P04: { label: "Pökler", key: "P04_pokler_imipolex_ilse", cssVar: "--strand-pokler" },
  P05: { label: "Pointsman", key: "P05_pointsman_white_visitation", cssVar: "--strand-pointsman" },
  P06: { label: "Counterforce", key: "P06_pirate_roger_jessica_counterforce", cssVar: "--strand-counterforce" },
  P07: { label: "Tchitcherine", key: "P07_tchitcherine_soviet_line", cssVar: "--strand-tchitcherine" },
  P08: { label: "Film/Body", key: "P08_film_body_image", cssVar: "--strand-film" },
};

const PLOT_IDS = ['P01', 'P02', 'P03', 'P04', 'P05', 'P06', 'P07', 'P08'];

const p4Episodes = (unifiedData as any[])
  .filter(e => e.part === 4)
  .sort((a, b) => a.global_index - b.global_index);

const LABEL_W = 120;
const EP_W = 72;
const EP_GAP = 10;
const ROW_H = 64;
const PAD_TOP = 32;
const PAD_BOTTOM = 40;
const BAR_MAX_H = 52;
const LEGEND_H = 32;
const TOTAL_W = LABEL_W + p4Episodes.length * (EP_W + EP_GAP);
const TOTAL_H = PAD_TOP + PLOT_IDS.length * ROW_H + PAD_BOTTOM + LEGEND_H;

interface BarCell {
  x: number;
  y: number;
  w: number;
  h: number;
  cssVar: string;
  opacity: number;
  epId: string;
  plotline: string;
  intensity: number;
}

const barCells: BarCell[] = [];

for (let pi = 0; pi < PLOT_IDS.length; pi++) {
  const pid = PLOT_IDS[pi];
  const pm = PLOTLINE_MAP[pid];
  const rowY = PAD_TOP + pi * ROW_H;

  for (let ei = 0; ei < p4Episodes.length; ei++) {
    const ep = p4Episodes[ei];
    const plotlines = ep.plotlines || {};
    let intensity = 0;
    for (const [k, v] of Object.entries(plotlines)) {
      if (k.startsWith(pid + '_')) {
        intensity = (v as any).intensity || 0;
        break;
      }
    }
    if (intensity === 0) continue;

    const barH = (intensity / 3) * BAR_MAX_H;
    const x = LABEL_W + ei * (EP_W + EP_GAP);
    const cy = rowY + (ROW_H - barH) / 2;
    const opacities = [0.04, 0.35, 0.6, 1.0];

    barCells.push({
      x: x + 3,
      y: cy,
      w: EP_W - 6,
      h: barH,
      cssVar: pm.cssVar,
      opacity: opacities[intensity],
      epId: ep.episode_id,
      plotline: pm.label,
      intensity,
    });
  }
}

const CONVERGENCE_EPISODE = '4.12';
const convIdx = p4Episodes.findIndex(e => e.episode_id === CONVERGENCE_EPISODE);
const convX = LABEL_W + convIdx * (EP_W + EP_GAP) + EP_W / 2;

const LEGEND_Y = PAD_TOP + PLOT_IDS.length * ROW_H + PAD_BOTTOM;
const LEGEND_ITEMS = [
  { label: 'Low', intensity: 1 },
  { label: 'Medium', intensity: 2 },
  { label: 'High', intensity: 3 },
];
---

<div class="convergence-plate-wrap">
  <svg
    class="convergence-plate"
    viewBox={`0 0 ${TOTAL_W} ${TOTAL_H}`}
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-label="Part 4 plotline convergence toward the final episode"
  >
    {/* Row labels */}
    {PLOT_IDS.map((pid, pi) => {
      const pm = PLOTLINE_MAP[pid];
      return (
        <text
          class="conv-label"
          x={LABEL_W - 6}
          y={PAD_TOP + pi * ROW_H + ROW_H / 2 + 3}
          text-anchor="end"
          style={`fill: var(${pm.cssVar})`}
        >
          {pm.label}
        </text>
      );
    })}

    {/* Row separators */}
    {PLOT_IDS.map((_, pi) => (
      <line
        x1={LABEL_W}
        y1={PAD_TOP + pi * ROW_H}
        x2={TOTAL_W - EP_GAP}
        y2={PAD_TOP + pi * ROW_H}
        stroke="var(--color-text-dim)"
        stroke-width="0.3"
        opacity="0.2"
      />
    ))}

    {/* Episode column labels along bottom */}
    {p4Episodes.map((ep: any, ei: number) => (
      <text
        class="conv-ep-label"
        x={LABEL_W + ei * (EP_W + EP_GAP) + EP_W / 2}
        y={PAD_TOP + PLOT_IDS.length * ROW_H + 16}
        text-anchor="middle"
        fill="var(--color-text-dim)"
      >
        {ep.episode_id}
      </text>
    ))}

    {/* Intensity bars */}
    {barCells.map(cell => (
      <rect
        x={cell.x}
        y={cell.y}
        width={cell.w}
        height={cell.h}
        rx="3"
        style={`fill: var(${cell.cssVar})`}
        opacity={cell.opacity}
      >
        <title>{cell.epId}: {cell.plotline}</title>
      </rect>
    ))}

    {/* Convergence marker on 4.12 */}
    <line
      x1={convX}
      y1={PAD_TOP - 10}
      x2={convX}
      y2={PAD_TOP + PLOT_IDS.length * ROW_H + 4}
      stroke="var(--color-accent)"
      stroke-width="1.5"
      stroke-dasharray="4,3"
      opacity="0.7"
    />
    <text
      class="conv-convergence-label"
      x={convX}
      y={PAD_TOP - 14}
      text-anchor="middle"
      fill="var(--color-accent)"
    >
      convergence
    </text>

    {/* Episode column hit areas */}
    {p4Episodes.map((ep: any, ei: number) => (
      <rect
        class="conv-col-hit"
        x={LABEL_W + ei * (EP_W + EP_GAP)}
        y={0}
        width={EP_W}
        height={PAD_TOP + PLOT_IDS.length * ROW_H + PAD_BOTTOM}
        fill="transparent"
        data-ep={ep.episode_id}
      >
        <title>{ep.episode_id}</title>
      </rect>
    ))}

    {/* Intensity legend */}
    <text
      x={LABEL_W}
      y={LEGEND_Y + 18}
      class="conv-legend-label"
      fill="var(--color-text-dim)"
    >Presence:</text>
    {LEGEND_ITEMS.map((item, i) => {
      const lx = LABEL_W + 90 + i * 90;
      const barH = (item.intensity / 3) * 20;
      const opacities = [0.04, 0.35, 0.6, 1.0];
      return (
        <>
          <rect
            x={lx}
            y={LEGEND_Y + 18 - barH}
            width={18}
            height={barH}
            rx="2.5"
            fill="var(--color-accent)"
            opacity={opacities[item.intensity]}
          />
          <text
            x={lx + 26}
            y={LEGEND_Y + 20}
            class="conv-legend-label"
            fill="var(--color-text-dim)"
          >{item.label}</text>
        </>
      );
    })}

    {/* Floating tooltip */}
    <text
      class="conv-tooltip"
      id="conv-tooltip"
      x="0" y="0"
      text-anchor="middle"
      fill="var(--color-text)"
      opacity="0"
    ></text>
  </svg>
</div>

<script>
  {
    const wrap = document.querySelector('.convergence-plate-wrap');
    const tooltip = document.getElementById('conv-tooltip') as SVGTextElement | null;
    const cols = wrap?.querySelectorAll('.conv-col-hit');
    const bars = wrap?.querySelectorAll('rect[rx="3"]');
    const labels = wrap?.querySelectorAll('.conv-label');

    if (tooltip && cols) {
      cols.forEach(col => {
        col.addEventListener('mouseenter', () => {
          const ep = (col as SVGElement).dataset.ep || '';
          const cx = parseFloat(col.getAttribute('x') || '0') +
                     parseFloat(col.getAttribute('width') || '0') / 2;
          tooltip.textContent = ep;
          tooltip.setAttribute('x', String(cx));
          tooltip.setAttribute('y', '12');
          tooltip.setAttribute('opacity', '1');

          col.setAttribute('fill', 'var(--color-accent)');
          col.setAttribute('opacity', '0.06');
        });

        col.addEventListener('mouseleave', () => {
          tooltip.setAttribute('opacity', '0');
          col.setAttribute('fill', 'transparent');
          col.setAttribute('opacity', '0');
        });
      });

      labels?.forEach((lbl, pi) => {
        lbl.addEventListener('mouseenter', () => {
          (lbl as SVGElement).style.fontWeight = 'bold';
          bars?.forEach(bar => {
            const by = parseFloat(bar.getAttribute('y') || '0');
            const bh = parseFloat(bar.getAttribute('height') || '0');
            const barCenter = by + bh / 2;
            const ROW_H = 64;
            const PAD_TOP = 32;
            const rowCenter = PAD_TOP + pi * ROW_H + ROW_H / 2;
            if (Math.abs(barCenter - rowCenter) < ROW_H / 2) {
              bar.setAttribute('opacity', '1');
            } else {
              bar.setAttribute('opacity', '0.08');
            }
          });
        });

        lbl.addEventListener('mouseleave', () => {
          (lbl as SVGElement).style.fontWeight = '';
          bars?.forEach(bar => {
            bar.setAttribute('opacity', (bar as any)._origOpacity || bar.getAttribute('opacity') || '1');
          });
        });
      });

      bars?.forEach(bar => {
        (bar as any)._origOpacity = bar.getAttribute('opacity');
      });
    }
  }
</script>

<style>
  .convergence-plate-wrap {
    overflow-x: visible;
    border-radius: 2px;
  }

  .convergence-plate {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .conv-tooltip {
    font-size: 10px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  .conv-label {
    font-size: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .conv-ep-label {
    font-size: 9px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .conv-convergence-label {
    font-size: 9px;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .conv-legend-label {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }

  .conv-col-hit:hover {
    fill: var(--color-accent) !important;
    opacity: 0.06 !important;
  }

  @media (max-width: 768px) {
    .convergence-plate-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .convergence-plate {
      width: max(100%, 600px);
      height: auto;
    }
  }
</style>
