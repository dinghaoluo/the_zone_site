  { id: "4.12", part: 4, words: 11552 },
];

const partNames = [
  "", // 0-indexed padding
  "Beyond the Zero",
  "Un Perm' au Casino Hermann Goering",
  "In the Zone",
  "The Counterforce",
];

const maxWords = Math.max(...episodes.map((e) => e.words));

const partColors: Record<number, string> = {
  1: "var(--color-part-1)",
  2: "var(--color-part-2)",
  3: "var(--color-part-3)",
  4: "var(--color-part-4)",
};

const BAR_WIDTH = 8;
const BAR_GAP = 3;
const PART_GAP = 16;
const MAX_HEIGHT = 160;

let x = 0;
type BarData = { x: number; height: number; color: string; id: string; words: number; part: number };
const bars: BarData[] = [];
let lastPart = 0;

for (const ep of episodes) {
  if (ep.part !== lastPart && lastPart !== 0) x += PART_GAP;
  const height = (ep.words / maxWords) * MAX_HEIGHT;
  bars.push({ x, height, color: partColors[ep.part], id: ep.id, words: ep.words, part: ep.part });
  x += BAR_WIDTH + BAR_GAP;
  lastPart = ep.part;
}

const totalWidth = x - BAR_GAP;
const SVG_HEIGHT = MAX_HEIGHT + 40;

const partGroups = [1, 2, 3, 4].map((p) => {
  const partBars = bars.filter((b) => b.part === p);
  const minX = Math.min(...partBars.map((b) => b.x));
  const maxX = Math.max(...partBars.map((b) => b.x)) + BAR_WIDTH;
  return { part: p, name: partNames[p], centerX: (minX + maxX) / 2 };
});
---

<div class="preview-wrap">
  <div class="preview-header">
    <h3>Structural Fingerprint</h3>
    <p class="preview-subtitle">73 episodes across four parts &mdash; bar height proportional to word count</p>
  </div>

  <div class="preview-svg-wrap">
    <svg
      viewBox={`-4 0 ${totalWidth + 8} ${SVG_HEIGHT}`}
      preserveAspectRatio="xMidYMid meet"
      class="fingerprint-svg"
      role="img"
      aria-label="Structural fingerprint of Gravity's Rainbow showing 73 episodes as vertical bars grouped by part"
    >
      {bars.map((b) => (
        <rect
          x={b.x}
          y={MAX_HEIGHT - b.height}
          width={BAR_WIDTH}
          height={b.height}
          fill={b.color}
          opacity="0.7"
          rx="1"
        >
          <title>{b.id}: {b.words.toLocaleString()} words</title>
        </rect>
      ))}

      {partGroups.map((pg) => (
        <text
          x={pg.centerX}
          y={MAX_HEIGHT + 18}
          text-anchor="middle"
          fill="var(--color-text-dim)"
          font-size="9"
          font-family="var(--font-mono)"
        >
          Part {pg.part}
        </text>
      ))}
    </svg>
  </div>

  <div class="preview-stats">
    <div class="stat">
      <span class="stat-value">73</span>
      <span class="stat-label">Episodes</span>
    </div>
    <div class="stat">
      <span class="stat-value">138</span>
      <span class="stat-label">Characters</span>
    </div>
    <div class="stat">
      <span class="stat-value">333k</span>
      <span class="stat-label">Words</span>
    </div>
    <div class="stat">
      <span class="stat-value">4</span>
      <span class="stat-label">Parts</span>
    </div>
  </div>
</div>

<style>
  .preview-wrap {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: var(--space-xl);
    overflow: hidden;
  }

  .preview-header {
    margin-bottom: var(--space-lg);
  }

  .preview-header h3 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .preview-subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-dim);
  }

  .preview-svg-wrap {
    overflow-x: auto;
    margin-bottom: var(--space-xl);
  }

  .fingerprint-svg {
    display: block;
    width: 100%;
    max-height: 200px;
  }

  .preview-stats {
    display: flex;
    gap: var(--space-xl);
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-lg);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 640px) {
    .preview-wrap {
      padding: var(--space-lg);
    }

    .preview-stats {
      flex-wrap: wrap;
      gap: var(--space-lg);
    }
  }
</style>
