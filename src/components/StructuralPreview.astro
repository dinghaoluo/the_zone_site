---
const episodes = [
  2078, 4004, 1322, 4164, 3365, 2095, 2401, 2508, 3178, 4564,
  624, 4828, 4054, 10113, 2836, 7530, 3987, 4335, 6311, 2898, 1565,
  3542, 7003, 9223, 4623, 3261, 2004, 9018, 3966,
  5718, 8354, 6749, 3129, 10251, 5199, 5178, 2992, 861, 2414,
  16777, 6657, 3893, 5067, 2147, 3996, 3018, 1559, 5772, 5575,
  1482, 6260, 724, 4859, 3818, 2660, 1449, 4464, 1549, 4884, 8140, 2947,
  3391, 6077, 7076, 3341, 4811, 11649, 2358, 4936, 3372, 4084, 780, 11552,
];

const parts = [21, 8, 32, 12];
const partColors = [
  "var(--color-part-1)",
  "var(--color-part-2)",
  "var(--color-part-3)",
  "var(--color-part-4)",
];

const maxWords = Math.max(...episodes);
const BAR_W = 4;
const BAR_GAP = 1.5;
const PART_GAP = 6;
const MAX_H = 32;

let x = 0;
let partIdx = 0;
let countInPart = 0;

type Bar = { x: number; h: number; fill: string };
const bars: Bar[] = [];

for (const w of episodes) {
  if (countInPart >= parts[partIdx]) {
    partIdx++;
    countInPart = 0;
    x += PART_GAP;
  }
  bars.push({ x, h: (w / maxWords) * MAX_H, fill: partColors[partIdx] });
  x += BAR_W + BAR_GAP;
  countInPart++;
}

const totalW = x - BAR_GAP;
---

<svg
  class="sparkline"
  viewBox={`0 0 ${totalW} ${MAX_H}`}
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label="Episode word counts across four parts"
>
  {bars.map((b) => (
    <rect
      x={b.x}
      y={MAX_H - b.h}
      width={BAR_W}
      height={b.h}
      fill={b.fill}
      opacity="0.6"
    />
  ))}
</svg>

<style>
  .sparkline {
    display: block;
    width: 100%;
    height: 3.5rem;
  }
</style>
