---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

const links = [
  { href: `${base}episodes/`, label: "Episodes" },
  { href: `${base}dissolution/`, label: "Dissolution" },
  { href: `${base}network/`, label: "Network" },
  { href: `${base}strands/`, label: "Strands" },
];

function isActive(href: string): boolean {
  return pathname.startsWith(href);
}
---

<nav class="nav" aria-label="Primary">
  <div class="nav-inner container">
    <a class="nav-brand" href={base}>The Zone</a>
    <ul class="nav-links" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[{ active: isActive(href) }]}
            aria-current={isActive(href) ? "page" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11, 11, 15, 0.85);
    border-bottom: 1px solid var(--color-border-subtle);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .nav-brand:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-dim);
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-links a.active {
    color: var(--color-accent);
  }

  .nav-links a.active::after {
    width: 100%;
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: var(--space-md);
    }

    .nav-links a {
      font-size: var(--text-xs);
    }
  }
</style>
