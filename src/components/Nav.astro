---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sitePath = (path: string) => `${base}/${path.replace(/^\//, '')}`;
const pathname = Astro.url.pathname;

const links = [
  { href: sitePath("braid/"), label: "Braid" },
  { href: sitePath("dissolution/"), label: "Dissolution" },
  { href: sitePath("network/"), label: "Network" },
];

function isActive(href: string): boolean {
  return pathname.startsWith(href);
}
---

<nav class="nav" aria-label="Primary">
  <div class="nav-inner container">
    <a class="nav-brand" href={`${base}/`}>The Zone</a>
    <ul class="nav-links" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[{ active: isActive(href) }]}
            aria-current={isActive(href) ? "page" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11, 11, 15, 0.78);
    border-bottom: 1px solid var(--color-border-subtle);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 3.5rem;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: var(--color-text);
  }

  .nav-brand:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 1.4rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-dim);
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-text-secondary);
  }

  .nav-links a.active {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .nav-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
      padding-top: var(--space-sm);
      padding-bottom: var(--space-sm);
    }

    .nav-links {
      gap: 0.9rem;
      flex-wrap: wrap;
    }

    .nav-links a {
      font-size: var(--text-xs);
    }
  }
</style>
