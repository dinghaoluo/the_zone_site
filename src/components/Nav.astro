---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sitePath = (path: string) => `${base}/${path.replace(/^\//, '')}`;
const pathname = Astro.url.pathname;

const links = [
  { href: sitePath("braid/"), label: "Braid" },
  { href: sitePath("scenes/"), label: "Scenes" },
  { href: sitePath("dissolution/"), label: "Dissolution" },
  { href: sitePath("network/"), label: "Network" },
];

function isActive(href: string): boolean {
  return pathname.startsWith(href);
}
---

<nav class="nav" aria-label="Primary">
  <div class="nav-inner container">
    <a class="nav-brand" href={`${base}/`}>The Zone</a>
    <div class="nav-right">
      <ul class="nav-links" role="list">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[{ active: isActive(href) }]}
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
        <span class="theme-label" data-theme-label="d">d</span>
        <span class="theme-sep">/</span>
        <span class="theme-label" data-theme-label="l">l</span>
      </button>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    function updateLabels() {
      const current = document.documentElement.dataset.theme || 'dark';
      toggle!.querySelectorAll('.theme-label').forEach(el => {
        const val = (el as HTMLElement).dataset.themeLabel;
        (el as HTMLElement).classList.toggle('active',
          (current === 'dark' && val === 'd') || (current === 'light' && val === 'l')
        );
      });
    }
    updateLabels();

    toggle.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      updateLabels();
    });
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-nav-bg);
    border-bottom: 1px solid var(--color-border-subtle);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 3.5rem;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-size: var(--text-base);
    letter-spacing: 0.06em;
    color: var(--color-text);
  }

  .nav-brand:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 1.4rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--color-text-dim);
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-text-secondary);
  }

  .nav-links a.active {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .nav-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
      padding-top: var(--space-sm);
      padding-bottom: var(--space-sm);
    }

    .nav-right {
      width: 100%;
      justify-content: space-between;
    }

    .nav-links {
      gap: 0.9rem;
      flex-wrap: wrap;
    }

    .nav-links a {
      font-size: var(--text-xs);
    }
  }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: baseline;
    gap: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.2rem 0;
    color: var(--color-text-dim);
    transition: color 0.2s;
  }

  .theme-toggle:hover {
    color: var(--color-text-secondary);
  }

  .theme-sep {
    color: var(--color-border);
    margin: 0 0.15rem;
  }

  .theme-label {
    opacity: 0.4;
    transition: opacity 0.2s, color 0.2s;
  }

  .theme-label.active {
    opacity: 1;
    color: var(--color-accent);
  }
</style>
