---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="episode-plate" id="episode-sequence-plate">
  <header class="plate-head">
    <span class="plate-num">Plate I</span>
    <h3 class="plate-title">Episode sequence</h3>
  </header>

  <div class="view-line" id="episode-sequence-controls">
    <span class="view-label">View</span>
    <button class="view-btn active" data-mode="length">Length</button>
    <span class="view-sep">/</span>
    <button class="view-btn" data-mode="density">Grain</button>
  </div>

  <div class="sequence-layout">
    <div class="sequence-main">
      <div class="sequence-scroll">
        <div
          id="episode-sequence-canvas"
          class="sequence-canvas"
          data-base={base}
        ></div>
      </div>
    </div>
    <aside class="sequence-rail">
      <div id="episode-sequence-note" class="sequence-note"></div>
      <div id="episode-sequence-key" class="sequence-key">
        <div class="key-head">Parts</div>
      </div>
    </aside>
  </div>
</div>

<script>
  import * as d3 from 'd3';

  type Mode = 'length' | 'density';
  type Anchor = {
    episode_id: string;
    anchor_label: string;
    anchor_type: string;
    plot_anchor: string;
    interpretive_note: string;
    motif_tags: string;
    display_priority: number;
    quote_status: string;
  };
  type AnchorQuote = {
    episode_id: string;
    anchor_label: string;
    approved_quote: string;
    quote_word_count: number;
    recommended_public_location: string;
    why_this_quote_helps: string;
    public_note: string;
  };
  type Episode = {
    global_index: number;
    episode_id: string;
    part: number;
    part_title: string;
    episode_in_part: number;
    word_count: number;
    paragraph_count: number;
    words_per_paragraph: number;
    paragraphs_per_1000: number;
    anchor?: Anchor;
    quote?: AnchorQuote;
  };

  const canvas = document.getElementById('episode-sequence-canvas') as HTMLElement;
  const noteEl = document.getElementById('episode-sequence-note') as HTMLElement;
  const keyEl = document.getElementById('episode-sequence-key') as HTMLElement;
  const base = canvas.dataset.base || '';

  const formatInt = d3.format(',');
  const formatOne = d3.format('.1f');
  const partColours = new Map<number, string>([
    [1, 'var(--color-part-1)'],
    [2, 'var(--color-part-2)'],
    [3, 'var(--color-part-3)'],
    [4, 'var(--color-part-4)'],
  ]);
  const partRoman = new Map<number, string>([
    [1, 'I'],
    [2, 'II'],
    [3, 'III'],
    [4, 'IV'],
  ]);

  const W = 1480;
  const H = 680;
  const margin = { top: 128, right: 46, bottom: 112, left: 56 };
  const baseline = H - margin.bottom;
  const plotTop = margin.top;
  let mode: Mode = 'length';
  let locked: number | null = null;

  const svg = d3.select(canvas)
    .append('svg')
    .attr('viewBox', `0 0 ${W} ${H}`)
    .attr('preserveAspectRatio', 'xMidYMid meet')
    .attr('role', 'img')
    .attr('aria-label', 'Episode sequence for the seventy-three episodes of the novel');

  svg.append('rect')
    .attr('width', W)
    .attr('height', H)
    .attr('fill', 'var(--color-surface)')
    .attr('rx', 2);

  const gParts = svg.append('g').attr('class', 'parts');
  const gRules = svg.append('g').attr('class', 'rules');
  const gMarks = svg.append('g').attr('class', 'marks');
  const gAnnotations = svg.append('g').attr('class', 'annotations');
  const gHits = svg.append('g').attr('class', 'hits');

  noteEl.innerHTML = `
    <p class="note-title">Loading Score</p>
    <p class="note-body">Episode metadata is being loaded.</p>
  `;

  function showLoadError(error: unknown) {
    console.error('Episode sequence plate failed to load', error);
    noteEl.innerHTML = `
      <p class="note-title">Data Unavailable</p>
      <p class="note-body">The episode sequence or anchor data could not be loaded. A public-safe CSV may be missing or unreadable.</p>
    `;
  }

  function escapeHtml(value: string) {
    return value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    }[char] || char));
  }

  function fetchText(path: string, label: string) {
    return fetch(path).then((response) => {
      if (!response.ok) throw new Error(`HTTP ${response.status} while loading ${label}`);
      return response.text();
    });
  }

  Promise.all([
    fetchText(`${base}/data/base/episode_metadata_public.csv`, 'episode metadata'),
    fetchText(`${base}/data/base/episode_anchors_public.csv`, 'episode anchors'),
    fetchText(`${base}/data/base/episode_anchor_quotes_public.csv`, 'episode anchor quotes'),
  ])
    .then(([metadataText, anchorText, quoteText]) => {
      const anchors = d3.csvParse(anchorText, (d) => ({
        episode_id: d.episode_id!,
        anchor_label: d.anchor_label!,
        anchor_type: d.anchor_type!,
        plot_anchor: d.plot_anchor!,
        interpretive_note: d.interpretive_note!,
        motif_tags: d.motif_tags || '',
        display_priority: +(d.display_priority || 0),
        quote_status: d.quote_status || '',
      })) as Anchor[];

      const quotes = d3.csvParse(quoteText, (d) => ({
        episode_id: d.episode_id!,
        anchor_label: d.anchor_label!,
        approved_quote: d.approved_quote!,
        quote_word_count: +(d.quote_word_count || 0),
        recommended_public_location: d.recommended_public_location!,
        why_this_quote_helps: d.why_this_quote_helps!,
        public_note: d.public_note!,
      })) as AnchorQuote[];

      if (
        anchors.length === 0 ||
        quotes.some((d) => !Number.isFinite(d.quote_word_count) || d.quote_word_count > 25)
      ) {
        throw new Error('Episode anchor or quote layer did not match the expected public fields');
      }

      const anchorMap = new Map(anchors.map((d) => [d.episode_id, d]));
      const quoteMap = new Map(quotes.map((d) => [d.episode_id, d]));

      const episodes = d3.csvParse(metadataText, (d) => {
        const wordCount = +d.word_count!;
        const paragraphCount = +d.paragraph_count!;
        const episodeId = d.episode_id!;
        return {
          global_index: +d.global_index!,
          episode_id: episodeId,
          part: +d.part!,
          part_title: d.part_title!,
          episode_in_part: +d.episode_in_part!,
          word_count: wordCount,
          paragraph_count: paragraphCount,
          words_per_paragraph: wordCount / paragraphCount,
          paragraphs_per_1000: paragraphCount / wordCount * 1000,
          anchor: anchorMap.get(episodeId),
          quote: quoteMap.get(episodeId),
        };
      }) as Episode[];

      if (
        episodes.length === 0 ||
        episodes.some((d) =>
          !Number.isFinite(d.global_index) ||
          !Number.isFinite(d.part) ||
          !Number.isFinite(d.word_count) ||
          !Number.isFinite(d.paragraph_count) ||
          !Number.isFinite(d.paragraphs_per_1000)
        )
      ) {
        throw new Error('Episode metadata did not match the expected data fields');
      }

      const x = d3.scaleBand<number>()
        .domain(episodes.map((d) => d.global_index))
        .range([margin.left, W - margin.right])
        .paddingInner(0.28);
      const bw = x.bandwidth();
      const xMid = (d: Episode) => x(d.global_index)! + bw / 2;

      const yWord = d3.scaleLinear()
        .domain([0, d3.max(episodes, (d) => d.word_count)!])
        .nice()
        .range([baseline, plotTop]);

      const yDensity = d3.scaleLinear()
        .domain([0, d3.max(episodes, (d) => d.paragraphs_per_1000)!])
        .nice()
        .range([baseline, plotTop + 24]);

      const lengthGuideValues = [5000, 10000, 15000];
      const densityGuideValues = [10, 20, 30];

      function episodeTop(d: Episode, selectedMode: Mode = mode) {
        return selectedMode === 'length'
          ? yWord(d.word_count)
          : yDensity(d.paragraphs_per_1000);
      }

      function activeGuideValues() {
        return mode === 'length' ? lengthGuideValues : densityGuideValues;
      }

      function guideTop(value: number) {
        return mode === 'length' ? yWord(value) : yDensity(value);
      }

      function guideLabel(value: number) {
        return mode === 'length'
          ? `${formatInt(value)} words`
          : `${formatOne(value)} para / 1k words`;
      }

      function partTitleLines(title: string) {
        if (title === "Un Perm' au Casino Hermann Goering") {
          return ["Un Perm' au Casino", "Hermann Goering"];
        }
        return [title];
      }

      function renderGuides() {
        const guides = gRules.selectAll<SVGGElement, number>('g.guide')
          .data(activeGuideValues(), (d) => `${mode}-${d}`);

        guides.exit().remove();

        const entered = guides.enter()
          .append('g')
          .attr('class', 'guide');

        entered.append('line')
          .attr('x1', margin.left)
          .attr('x2', W - margin.right)
          .attr('stroke', 'var(--color-border-subtle)')
          .attr('stroke-width', 1);

        entered.append('text')
          .attr('x', margin.left + 4)
          .attr('y', -10)
          .attr('fill', 'var(--color-text-dim)')
          .attr('font-family', 'var(--font-mono)')
          .attr('font-size', 14);

        const merged = entered.merge(guides);
        merged.attr('transform', (d) => `translate(0,${guideTop(d)})`);
        merged.select('text').text((d) => guideLabel(d));
      }

      const parts = d3.groups(episodes, (d) => d.part)
        .map(([part, rows]) => ({
          part,
          title: rows[0].part_title,
          rows,
          colour: partColours.get(part) || 'var(--color-text-dim)',
          start: rows[0],
          end: rows[rows.length - 1],
        }))
        .sort((a, b) => a.part - b.part);

      gParts.selectAll('rect')
        .data(parts)
        .join('rect')
        .attr('x', (d) => x(d.start.global_index)! - bw * 0.55)
        .attr('y', plotTop - 66)
        .attr('width', (d) => x(d.end.global_index)! - x(d.start.global_index)! + bw * 2.1)
        .attr('height', baseline - plotTop + 94)
        .attr('fill', (d) => d.colour)
        .attr('fill-opacity', 0.035);

      gParts.selectAll('line.boundary')
        .data(parts.slice(1))
        .join('line')
        .attr('class', 'boundary')
        .attr('x1', (d) => x(d.start.global_index)! - bw * 0.75)
        .attr('x2', (d) => x(d.start.global_index)! - bw * 0.75)
        .attr('y1', plotTop - 74)
        .attr('y2', baseline + 48)
        .attr('stroke', 'var(--color-border)')
        .attr('stroke-width', 1);

      const partLabels = gParts.selectAll('g.part-label')
        .data(parts)
        .join('g')
        .attr('class', 'part-label')
        .attr('transform', (d) => {
          const xStart = x(d.start.global_index)!;
          const xEnd = x(d.end.global_index)! + bw;
          return `translate(${(xStart + xEnd) / 2}, ${plotTop - 98})`;
        });

      partLabels.append('text')
        .attr('text-anchor', 'middle')
        .attr('fill', 'var(--color-text-secondary)')
        .attr('font-family', 'var(--font-mono)')
        .attr('font-size', 15)
        .text((d) => `Part ${partRoman.get(d.part)}`);

      partLabels.selectAll('text.part-title-line')
        .data((d) => partTitleLines(d.title).map((line, i) => ({ line, i })))
        .join('text')
        .attr('class', 'part-title-line')
        .attr('y', (d) => 26 + d.i * 18)
        .attr('text-anchor', 'middle')
        .attr('fill', 'var(--color-text-dim)')
        .attr('font-family', 'var(--font-heading)')
        .attr('font-size', 16)
        .attr('font-style', 'italic')
        .text((d) => d.line);

      gRules.append('line')
        .attr('x1', margin.left)
        .attr('x2', W - margin.right)
        .attr('y1', baseline)
        .attr('y2', baseline)
        .attr('stroke', 'var(--color-border)')
        .attr('stroke-width', 1);

      renderGuides();

      const marks = gMarks.selectAll('g.episode-mark')
        .data(episodes)
        .join('g')
        .attr('class', 'episode-mark')
        .attr('transform', (d) => `translate(${x(d.global_index)},0)`);

      marks.append('rect')
        .attr('class', 'word-mark')
        .attr('x', 0)
        .attr('width', bw)
        .attr('fill', (d) => partColours.get(d.part) || 'var(--color-text-dim)')
        .attr('fill-opacity', 0.58);

      marks.append('line')
        .attr('class', 'stem')
        .attr('x1', bw / 2)
        .attr('x2', bw / 2)
        .attr('y1', baseline)
        .attr('stroke', 'var(--color-text-dim)')
        .attr('stroke-opacity', 0.32)
        .attr('stroke-width', 1);

      marks.selectAll('line.paragraph-tick')
        .data((d) => {
          const count = Math.max(2, Math.min(12, Math.round(Math.sqrt(d.paragraph_count))));
          return d3.range(count).map((i) => ({ i, count, episode: d }));
        })
        .join('line')
        .attr('class', 'paragraph-tick')
        .attr('x1', 1)
        .attr('x2', Math.max(2, bw - 1))
        .attr('stroke', 'var(--color-bg)')
        .attr('stroke-width', 1)
        .attr('stroke-opacity', 0.42);

      marks.append('circle')
        .attr('class', 'anchor-dot')
        .attr('cx', bw / 2)
        .attr('cy', baseline + 13)
        .attr('r', (d) => d.anchor ? (d.quote ? 4.2 : 3.2) : 0)
        .attr('fill', (d) => d.quote ? 'var(--color-accent)' : (partColours.get(d.part) || 'var(--color-text-dim)'))
        .attr('fill-opacity', (d) => d.anchor ? (d.quote ? 0.82 : 0.42) : 0)
        .attr('stroke', (d) => d.anchor ? 'var(--color-surface)' : 'none')
        .attr('stroke-width', 1);

      const longEpisodes = [...episodes]
        .sort((a, b) => b.word_count - a.word_count)
        .slice(0, 5)
        .sort((a, b) => a.global_index - b.global_index);

      const highDensityEpisodes = [...episodes]
        .sort((a, b) => b.paragraphs_per_1000 - a.paragraphs_per_1000)
        .slice(0, 5)
        .sort((a, b) => a.global_index - b.global_index);

      function activeAnnotations() {
        return mode === 'length' ? longEpisodes : highDensityEpisodes;
      }

      function renderAnnotations() {
        const annotations = gAnnotations.selectAll<SVGGElement, Episode>('g.annotation')
          .data(activeAnnotations(), (d) => d.episode_id);

        annotations.exit().remove();

        const entered = annotations.enter()
          .append('g')
          .attr('class', 'annotation');

        entered.append('line')
          .attr('x1', 0)
          .attr('x2', 0)
          .attr('y1', 5)
          .attr('y2', 22)
          .attr('stroke-width', 1);

        entered.append('text')
          .attr('x', 0)
          .attr('y', -2)
          .attr('text-anchor', 'middle')
          .attr('font-family', 'var(--font-mono)')
          .attr('font-size', 14);

        const merged = entered.merge(annotations);
        merged
          .attr('transform', (d) => `translate(${xMid(d)},${episodeTop(d) - 18})`);
        merged.select('line')
          .attr('stroke', mode === 'length' ? 'var(--color-accent-dim)' : 'var(--color-text-dim)');
        merged.select('text')
          .attr('fill', mode === 'length' ? 'var(--color-accent)' : 'var(--color-text-secondary)')
          .text((d) => d.episode_id);
      }

      renderAnnotations();

      const bottomLabels = episodes
        .filter((d) =>
          d.global_index === 1 ||
          d.global_index === episodes.length ||
          d.global_index % 10 === 0 ||
          parts.slice(1).some((part) => part.start.global_index === d.global_index)
        );

      const axisLabels = gRules.selectAll('g.axis-label')
        .data(bottomLabels)
        .join('g')
        .attr('class', 'axis-label')
        .attr('transform', (d) => `translate(${xMid(d)},${baseline + 30})`);

      axisLabels.append('line')
        .attr('y1', -7)
        .attr('y2', 0)
        .attr('stroke', 'var(--color-border)')
        .attr('stroke-width', 1);

      axisLabels.append('text')
        .attr('y', 18)
        .attr('text-anchor', 'middle')
        .attr('fill', 'var(--color-text-dim)')
        .attr('font-family', 'var(--font-mono)')
        .attr('font-size', 13)
        .text((d) => d.episode_id);

      const hitAreas = gHits.selectAll('rect.hit')
        .data(episodes)
        .join('rect')
        .attr('class', 'hit')
        .attr('x', (d) => x(d.global_index)! - bw * 0.35)
        .attr('y', plotTop - 20)
        .attr('width', bw * 1.7)
        .attr('height', baseline - plotTop + 54)
        .attr('fill', 'transparent')
        .attr('cursor', 'pointer');

      function activeTop(d: Episode) {
        return episodeTop(d);
      }

      function setNote(d: Episode | null) {
        if (!d) {
          const body = mode === 'length'
            ? 'Each vertical mark is an episode in reading order. Height shows word count; interior ticks carry paragraph structure. Small marks under the baseline identify selected public anchors.'
            : 'Grain view scales each mark by how tightly the episode is divided: more paragraph breaks per thousand words means denser, more fragmented prose. Filled anchor marks indicate approved short quotes.';
          noteEl.innerHTML = `
            <p class="note-title">Episode Sequence</p>
            <p class="note-stats">73 episodes / 4 parts / ${anchors.length} anchors / ${quotes.length} quotes</p>
            <p class="note-body">${body}</p>
          `;
          return;
        }

        const anchor = d.anchor;
        const quote = d.quote;
        const anchorTags = anchor?.motif_tags
          .split(';')
          .map((tag) => tag.trim())
          .filter(Boolean)
          .map((tag) => `<span>${escapeHtml(tag)}</span>`)
          .join('') || '';
        const anchorHtml = anchor ? `
          <div class="note-anchor">
            <p class="note-anchor-label">${escapeHtml(anchor.anchor_label)}</p>
            <p class="note-anchor-type">${escapeHtml(anchor.anchor_type)}</p>
            <p class="note-body">${escapeHtml(anchor.plot_anchor)}</p>
            <p class="note-body note-interpretive">${escapeHtml(anchor.interpretive_note)}</p>
            <div class="note-tags">${anchorTags}</div>
          </div>
        ` : `
          <p class="note-body">No public anchor is attached to this episode in the first anchor layer.</p>
        `;
        const quoteHtml = quote ? `
          <div class="note-quote">
            <p class="note-quote-label">Approved short quote</p>
            <q>${escapeHtml(quote.approved_quote)}</q>
            <p class="note-quote-note">${escapeHtml(quote.public_note)}</p>
          </div>
        ` : '';

        noteEl.innerHTML = `
          <p class="note-name">${d.episode_id}</p>
          <p class="note-community">${d.part_title} / episode ${d.episode_in_part}</p>
          <p class="note-stats">${formatInt(d.word_count)} words / ${formatInt(d.paragraph_count)} paragraphs</p>
          <p class="note-stats">${formatOne(d.words_per_paragraph)} words per paragraph</p>
          <p class="note-stats">${formatOne(d.paragraphs_per_1000)} paragraphs per 1,000 words</p>
          <p class="note-body">Global episode ${d.global_index} of 73.</p>
          ${anchorHtml}
          ${quoteHtml}
        `;
      }

      function tickY(tick: { i: number; count: number; episode: Episode }) {
        const top = activeTop(tick.episode);
        const height = baseline - top;
        return baseline - (tick.i + 1) * (height / (tick.count + 1));
      }

      function applyMode(nextMode: Mode) {
        mode = nextMode;
        document.querySelectorAll('#episode-sequence-controls .view-btn').forEach((button) => {
          button.classList.toggle('active', (button as HTMLElement).dataset.mode === mode);
        });

        renderGuides();
        renderAnnotations();

        const t = svg.transition().duration(350);
        marks.select<SVGRectElement>('rect.word-mark')
          .transition(t)
          .attr('y', (d) => activeTop(d))
          .attr('height', (d) => baseline - activeTop(d))
          .attr('fill-opacity', mode === 'length' ? 0.58 : 0.76);

        marks.select<SVGLineElement>('line.stem')
          .transition(t)
          .attr('y2', (d) => activeTop(d))
          .attr('stroke-opacity', mode === 'length' ? 0.32 : 0.16);

        marks.selectAll<SVGLineElement, { i: number; count: number; episode: Episode }>('line.paragraph-tick')
          .transition(t)
          .attr('y1', (d) => tickY(d))
          .attr('y2', (d) => tickY(d))
          .attr('stroke-opacity', mode === 'length' ? 0.42 : 0.78);

        if (locked === null) {
          marks.select<SVGRectElement>('rect.word-mark')
            .transition(t)
            .attr('stroke', 'none');
        }
        setNote(locked === null ? null : episodes.find((d) => d.global_index === locked) || null);
      }

      function highlightEpisode(d: Episode | null) {
        const t = svg.transition().duration(160);
        marks.select<SVGRectElement>('rect.word-mark')
          .transition(t)
          .attr('fill-opacity', (m) => {
            if (!d) return mode === 'length' ? 0.58 : 0.76;
            return m.global_index === d.global_index ? 0.95 : 0.22;
          })
          .attr('stroke', (m) => d && m.global_index === d.global_index ? 'var(--color-accent)' : 'none')
          .attr('stroke-width', (m) => d && m.global_index === d.global_index ? 1.2 : 0);

        marks.selectAll<SVGLineElement, { i: number; count: number; episode: Episode }>('line.paragraph-tick')
          .transition(t)
          .attr('stroke-opacity', (m) => {
            if (!d) return mode === 'length' ? 0.42 : 0.78;
            return m.episode.global_index === d.global_index ? 0.9 : 0.12;
          });

        marks.select<SVGCircleElement>('circle.anchor-dot')
          .transition(t)
          .attr('fill-opacity', (m) => {
            if (!m.anchor) return 0;
            if (!d) return m.quote ? 0.82 : 0.42;
            return m.global_index === d.global_index ? 1 : 0.18;
          })
          .attr('r', (m) => {
            if (!m.anchor) return 0;
            if (d && m.global_index === d.global_index) return m.quote ? 5.4 : 4.4;
            return m.quote ? 4.2 : 3.2;
          });
        setNote(d);
      }

      document.querySelectorAll('#episode-sequence-controls .view-btn').forEach((button) => {
        button.addEventListener('click', () => {
          locked = null;
          applyMode((button as HTMLElement).dataset.mode as Mode);
          highlightEpisode(null);
        });
      });

      hitAreas
        .on('mouseenter', (_event, d) => {
          if (locked === null) highlightEpisode(d);
        })
        .on('mouseleave', () => {
          if (locked === null) highlightEpisode(null);
        })
        .on('click', (event, d) => {
          event.stopPropagation();
          locked = locked === d.global_index ? null : d.global_index;
          highlightEpisode(locked === null ? null : d);
        });

      svg.on('click', () => {
        locked = null;
        highlightEpisode(null);
      });

      for (const part of parts) {
        const row = document.createElement('div');
        row.className = 'key-row';
        row.innerHTML = `
          <span class="key-tick" style="background:${part.colour}"></span>
          <span class="key-num">${partRoman.get(part.part)}</span>
          <span class="key-label">${part.title}</span>
          <span class="key-count">${part.rows.length}</span>
        `;
        keyEl.appendChild(row);
      }

      const anchorKey = document.createElement('div');
      anchorKey.className = 'key-anchor-block';
      anchorKey.innerHTML = `
        <div class="key-head">Anchor marks</div>
        <div class="key-row">
          <span class="key-dot"></span>
          <span class="key-label">Public anchor</span>
          <span class="key-count">${anchors.length}</span>
        </div>
        <div class="key-row">
          <span class="key-dot quoted"></span>
          <span class="key-label">Approved quote</span>
          <span class="key-count">${quotes.length}</span>
        </div>
      `;
      keyEl.appendChild(anchorKey);

      applyMode('length');
    })
    .catch(showLoadError);
</script>

