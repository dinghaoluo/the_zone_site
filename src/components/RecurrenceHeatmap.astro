---
import recurrenceText from "../../public/data/step_3a/phase_3a_recurrence_intensity_matrix_public.csv?raw";
import unifiedData from "../data/phase_3a_unified_episode_data_public.json";

const REG_LABELS: Record<string, string> = {
  species_extinction: "Species Extinction",
  colonial_genocide: "Colonial Genocide",
  holocaust_absence_or_adjacency: "Holocaust Adjacency",
  forced_labour_industrial_body_processing: "Forced Labour",
  postwar_technocratic_continuation: "Technocratic Continuation",
};

const REG_COLORS: Record<string, string> = {
  species_extinction: "var(--rec-species)",
  colonial_genocide: "var(--rec-colonial)",
  holocaust_absence_or_adjacency: "var(--rec-holocaust)",
  forced_labour_industrial_body_processing: "var(--rec-labour)",
  postwar_technocratic_continuation: "var(--rec-technocratic)",
};

const REG_KEYS = Object.keys(REG_LABELS);
const episodes = (unifiedData as any[]).sort((a, b) => a.global_index - b.global_index);

function parseCSV(raw: string) {
  const lines = raw.trim().split('\n');
  const headers = lines[0].split(',').map((h: string) => h.trim());
  const result = new Map();
  for (let i = 1; i < lines.length; i++) {
    const vals = lines[i].split(',');
    const eid = vals[0].trim();
    const row: any = {};
    for (let j = 1; j < headers.length; j++) row[headers[j]] = parseInt(vals[j], 10) || 0;
    result.set(eid, row);
  }
  return result;
}

const recurrenceMap = parseCSV(recurrenceText);

const COL_W = 14;
const COL_GAP = 2.5;
const ROW_H = 82;
const LABEL_W = 160;
const PAD_TOP = 28;
const PAD_BOTTOM = 30;
const LEGEND_H = 32;
const TOTAL_W = LABEL_W + episodes.length * (COL_W + COL_GAP);
const TOTAL_H = PAD_TOP + REG_KEYS.length * ROW_H + PAD_BOTTOM + LEGEND_H;

const INTENSITY_OPACITY = [0.0, 0.35, 0.65, 1.0];
const INTENSITY_HEIGHT  = [0, 30, 50, 68];

interface Cell {
  x: number;
  y: number;
  w: number;
  h: number;
  opacity: number;
  fill: string;
  epId: string;
  register: string;
  intensity: number;
}

const cells: Cell[] = [];
const activeEpisodes = new Set<string>();

for (let ci = 0; ci < episodes.length; ci++) {
  const ep = episodes[ci];
  const row = recurrenceMap.get(ep.episode_id) || {};
  const x = LABEL_W + ci * (COL_W + COL_GAP);

  for (let ri = 0; ri < REG_KEYS.length; ri++) {
    const rk = REG_KEYS[ri];
    const val = row[rk] || 0;
    if (val === 0) continue;
    activeEpisodes.add(ep.episode_id);
    const cellH = INTENSITY_HEIGHT[val];
    const cy = PAD_TOP + ri * ROW_H + (ROW_H - cellH) / 2;
    cells.push({
      x: x + 1, y: cy, w: COL_W - 2, h: cellH,
      opacity: INTENSITY_OPACITY[val],
      fill: REG_COLORS[rk],
      epId: ep.episode_id,
      register: REG_LABELS[rk],
      intensity: val,
    });
  }
}

const PART_BOUNDS = [
  { after: '1.21', before: '2.01' },
  { after: '2.08', before: '3.01' },
  { after: '3.32', before: '4.01' },
];
const partBoundaries: number[] = [];
for (const b of PART_BOUNDS) {
  const ai = episodes.findIndex((e: any) => e.episode_id === b.after);
  const bi = episodes.findIndex((e: any) => e.episode_id === b.before);
  if (ai >= 0 && bi >= 0) {
    const ax = LABEL_W + ai * (COL_W + COL_GAP) + COL_W + COL_GAP;
    const bx = LABEL_W + bi * (COL_W + COL_GAP);
    partBoundaries.push((ax + bx) / 2);
  }
}

const partLabels = ['I', 'II', 'III', 'IV'];
const partStarts = [0, 21, 29, 61];
const partLabelPositions = partStarts.map((start, i) => {
  const end = i < partStarts.length - 1 ? partStarts[i + 1] : episodes.length;
  const mid = Math.floor((start + end) / 2);
  return {
    x: LABEL_W + mid * (COL_W + COL_GAP) + COL_W / 2,
    label: partLabels[i],
  };
});

const KEY_EPISODES = [
  { id: '1.14', label: '1.14' },
  { id: '1.19', label: '1.19' },
  { id: '3.02', label: '3.02' },
  { id: '3.03', label: '3.03' },
  { id: '3.11', label: '3.11' },
  { id: '3.13', label: '3.13' },
  { id: '3.21', label: '3.21' },
  { id: '3.22', label: '3.22' },
  { id: '4.04', label: '4.04' },
  { id: '4.10', label: '4.10' },
  { id: '4.12', label: '4.12' },
];

const LEGEND_Y = PAD_TOP + REG_KEYS.length * ROW_H + PAD_BOTTOM;
const LEGEND_ITEMS = [
  { label: 'Low', opacity: INTENSITY_OPACITY[1], height: INTENSITY_HEIGHT[1] },
  { label: 'Medium', opacity: INTENSITY_OPACITY[2], height: INTENSITY_HEIGHT[2] },
  { label: 'High', opacity: INTENSITY_OPACITY[3], height: INTENSITY_HEIGHT[3] },
];
---

<div class="recurrence-heatmap-wrap">
  <svg
    class="recurrence-heatmap"
    viewBox={`0 0 ${TOTAL_W} ${TOTAL_H}`}
    preserveAspectRatio="xMinYMid meet"
    role="img"
    aria-label="Historical recurrences across seventy-three episodes"
  >
    {/* Register labels */}
    {REG_KEYS.map((rk, ri) => (
      <text
        class="reg-label"
        x={LABEL_W - 6}
        y={PAD_TOP + ri * ROW_H + ROW_H / 2 + 3}
        text-anchor="end"
        fill={REG_COLORS[rk]}
      >
        {REG_LABELS[rk]}
      </text>
    ))}

    {/* Row guides */}
    {REG_KEYS.map((_, ri) => (
      <line
        x1={LABEL_W}
        y1={PAD_TOP + ri * ROW_H}
        x2={TOTAL_W}
        y2={PAD_TOP + ri * ROW_H}
        stroke="var(--color-text-dim)"
        stroke-width="0.3"
        opacity="0.15"
      />
    ))}

    {/* Part boundary lines */}
    {partBoundaries.map(bx => (
      <line
        x1={bx} y1={0} x2={bx} y2={PAD_TOP + REG_KEYS.length * ROW_H + 6}
        stroke="var(--color-text-dim)"
        stroke-width="1"
        stroke-dasharray="4,3"
        opacity="0.35"
      />
    ))}

    {/* Intensity cells */}
    {cells.map(cell => (
      <rect
        x={cell.x}
        y={cell.y}
        width={cell.w}
        height={cell.h}
        rx="2.5"
        fill={cell.fill}
        opacity={cell.opacity}
      >
        <title>{cell.epId}: {cell.register}</title>
      </rect>
    ))}

    {/* Episode column hit areas */}
    {episodes.map((ep: any, ci: number) => {
      const hasRecurrence = activeEpisodes.has(ep.episode_id);
      return (
        <rect
          class={`rec-col-hit ${hasRecurrence ? 'active' : ''}`}
          x={LABEL_W + ci * (COL_W + COL_GAP)}
          y={0}
          width={COL_W}
          height={PAD_TOP + REG_KEYS.length * ROW_H + 6}
          fill="transparent"
          data-ep={ep.episode_id}
        >
          <title>{ep.episode_id}{hasRecurrence ? '' : ' (none)'}</title>
        </rect>
      );
    })}

    {/* Part number labels along bottom */}
    {partLabelPositions.map(pl => (
      <text
        class="rec-part-label"
        x={pl.x}
        y={PAD_TOP + REG_KEYS.length * ROW_H + 20}
        text-anchor="middle"
        fill="var(--color-text-dim)"
      >
        {pl.label}
      </text>
    ))}

    {/* Intensity legend */}
    <text
      x={LABEL_W}
      y={LEGEND_Y + 18}
      class="rec-legend-label"
      fill="var(--color-text-dim)"
    >Presence:</text>
    {LEGEND_ITEMS.map((item, i) => {
      const lx = LABEL_W + 90 + i * 90;
      return (
        <>
          <rect
            x={lx}
            y={LEGEND_Y + 18 - item.height / 3}
            width={18}
            height={item.height / 3}
            rx="2.5"
            fill="var(--rec-species)"
            opacity={item.opacity}
          />
          <text
            x={lx + 26}
            y={LEGEND_Y + 20}
            class="rec-legend-label"
            fill="var(--color-text-dim)"
          >{item.label}</text>
        </>
      );
    })}

    {/* Floating tooltip */}
    <text
      class="rec-ep-tooltip"
      id="rec-ep-tooltip"
      x="0" y="0"
      text-anchor="middle"
      fill="var(--color-text)"
      opacity="0"
    ></text>
  </svg>
</div>

<script>
  {
    const wrap = document.querySelector('.recurrence-heatmap-wrap');
    const tooltip = document.getElementById('rec-ep-tooltip') as SVGTextElement | null;
    const cols = wrap?.querySelectorAll('.rec-col-hit');
    const cells = wrap?.querySelectorAll('rect[rx="2.5"]');
    const labels = wrap?.querySelectorAll('.reg-label');

    if (tooltip && cols) {
      cols.forEach(col => {
        col.addEventListener('mouseenter', () => {
          const ep = (col as SVGElement).dataset.ep || '';
          const cx = parseFloat(col.getAttribute('x') || '0') +
                     parseFloat(col.getAttribute('width') || '0') / 2;
          tooltip.textContent = ep;
          tooltip.setAttribute('x', String(cx));
          tooltip.setAttribute('y', '-6');
          tooltip.setAttribute('opacity', '1');

          col.setAttribute('fill', 'var(--color-accent)');
          col.setAttribute('opacity', '0.06');
        });

        col.addEventListener('mouseleave', () => {
          tooltip.setAttribute('opacity', '0');
          col.setAttribute('fill', 'transparent');
          col.setAttribute('opacity', '0');
        });
      });

      labels?.forEach((lbl, ri) => {
        lbl.addEventListener('mouseenter', () => {
          (lbl as SVGElement).style.fontWeight = 'bold';
          cells?.forEach(cell => {
            const ry = parseFloat(cell.getAttribute('y') || '0');
            const ch = parseFloat(cell.getAttribute('height') || '0');
            const ROW_H = 82;
            const PAD_TOP = 28;
            const expectedCenter = PAD_TOP + ri * ROW_H + ROW_H / 2;
            if (Math.abs(ry + ch / 2 - expectedCenter) < ROW_H / 2) {
              cell.setAttribute('opacity', '1');
            } else {
              cell.setAttribute('opacity', '0.08');
            }
          });
        });

        lbl.addEventListener('mouseleave', () => {
          (lbl as SVGElement).style.fontWeight = '';
          cells?.forEach(cell => {
            cell.setAttribute('opacity', (cell as any)._origOpacity || cell.getAttribute('opacity') || '1');
          });
        });
      });

      cells?.forEach(cell => {
        (cell as any)._origOpacity = cell.getAttribute('opacity');
      });
    }
  }
</script>

<style>
  .recurrence-heatmap-wrap {
    overflow-x: visible;
    border-radius: 2px;
  }

  .recurrence-heatmap {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .rec-ep-tooltip {
    font-size: 10px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  .reg-label {
    font-size: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .rec-col-hit:hover {
    fill: var(--color-accent) !important;
    opacity: 0.06 !important;
  }

  .rec-ep-marker {
    font-size: 9px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .rec-part-label {
    font-size: 10px;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
  }

  .rec-legend-label {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }

  @media (max-width: 768px) {
    .recurrence-heatmap-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .recurrence-heatmap {
      width: max(100%, 700px);
      height: auto;
    }
  }
</style>
