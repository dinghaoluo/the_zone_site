---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const centralityAnnotations: Record<string, string> = {
  'Tyrone Slothrop': 'protagonist bridge',
  'Ned Pointsman': 'cross-community bridge',
  'Roger Mexico': 'counterforce anchor',
  'Weissmann / Blicero': 'rocket-system anchor',
  'Enzian': 'zone-line nexus',
  'Gerhardt von Göll': 'quest-system bridge',
  'Tchitcherine': 'parallel quest nexus',
  'Katje Borgesius': 'transition bridge',
  'Laszlo Jamf': 'backstory linchpin',
  'Pirate Prentice': 'counterforce link',
};

const dyadAnnotations: Record<string, string> = {
  'Jessica Swanlake — Roger Mexico': 'recurring pair',
  'Ned Pointsman — Roger Mexico': 'cross-community bridge',
  'Tantivy Mucker-Maffick — Tyrone Slothrop': 'early-novel pair',
  'Jessica Swanlake — Ned Pointsman': 'cross-role pair',
  'Ned Pointsman — Tyrone Slothrop': 'surveillance axis',
  'Katje Borgesius — Tyrone Slothrop': 'transition pair',
  'Weissmann / Blicero — Enzian': 'shared-system pair',
  'Roger Mexico — Tyrone Slothrop': 'counterforce-quest bridge',
  'Katje Borgesius — Ned Pointsman': 'institutional pair',
  'Ned Pointsman — Pirate Prentice': 'London-cluster pair',
};

const romanNumerals = ['i', 'ii', 'iii', 'iv', 'v'];
---

<div class="plate" id="plate-architecture">
  <header class="plate-head">
    <span class="plate-num">Plate II</span>
    <h3 class="plate-title">Network architecture</h3>
  </header>

  <div class="arch-grid" data-base={base}>
    <div class="arch-panel">
      <div class="panel-head">
        <span class="panel-letter">a</span>
        <span class="panel-label">Narrative zones</span>
        <span class="panel-sub">five communities by size</span>
      </div>
      <div id="community-list" class="community-list"></div>
    </div>
    <div class="arch-panel">
      <div class="panel-head">
        <span class="panel-letter">b</span>
        <span class="panel-label">Connective labour</span>
        <span class="panel-sub">betweenness centrality, top ten</span>
      </div>
      <div id="centrality-list" class="stat-list"></div>
    </div>
    <div class="arch-panel">
      <div class="panel-head">
        <span class="panel-letter">c</span>
        <span class="panel-label">Resilient bonds</span>
        <span class="panel-sub">strongest non-protagonist dyads</span>
      </div>
      <div id="dyads-list" class="stat-list"></div>
    </div>
  </div>
</div>

<script define:vars={{ centralityAnnotations, dyadAnnotations, romanNumerals }}>
  window.__archAnnotations = { centralityAnnotations, dyadAnnotations, romanNumerals };
</script>

<script>
  import * as d3 from 'd3';

  const grid = document.querySelector('.arch-grid') as HTMLElement;
  const base = grid?.dataset.base || '';
  const { centralityAnnotations, dyadAnnotations, romanNumerals } =
    (window as any).__archAnnotations || { centralityAnnotations: {}, dyadAnnotations: {}, romanNumerals: [] };

  Promise.all([
    fetch(`${base}/data/step_2d/master_network_layout_nodes_public.csv`).then(r => r.text()),
    fetch(`${base}/data/step_2d/master_network_layout_edges_public.csv`).then(r => r.text()),
  ]).then(([nodesText, edgesText]) => {
    const nodes = d3.csvParse(nodesText, d => ({
      id: d.id!, short_name: d.short_name!,
      community_id: +d.community_id!, community_label: d.community_label!,
      community_colour: d.community_colour!, weighted_degree: +d.weighted_degree!,
      degree: +d.degree!, betweenness_centrality: +d.betweenness_centrality!,
      episode_count: +d.episode_count!,
    }));

    const edges = d3.csvParse(edgesText, d => ({
      source: d.source!, target: d.target!, weight: +d.weight!,
      shared_episode_count: +d.shared_episode_count!,
      association_strength: +d.association_strength!, display_width: +d.display_width!,
    }));

    buildCommunities(nodes);
    buildCentrality(nodes);
    buildDyads(edges, nodes);
  });

  function buildCommunities(nodes: any[]) {
    const el = document.getElementById('community-list')!;
    const groups = d3.groups(nodes, (d: any) => d.community_id)
      .map(([id, members]) => ({
        id, label: members[0].community_label, colour: members[0].community_colour,
        count: members.length,
        top3: [...members].sort((a, b) => b.weighted_degree - a.weighted_degree).slice(0, 3),
      }))
      .sort((a, b) => b.count - a.count);

    for (const c of groups) {
      const row = document.createElement('div');
      row.className = 'community-entry';
      const ri = romanNumerals[c.id - 1] || String(c.id);
      row.innerHTML = `
        <span class="c-mark" style="background:${c.colour}"></span>
        <div class="c-body">
          <div class="c-head">
            <span class="c-num">${ri}.</span>
            <span class="c-label">${c.label}</span>
            <span class="c-count">${c.count}</span>
          </div>
          <div class="c-anchors">${c.top3.map((n: any) => n.short_name).join(' · ')}</div>
        </div>
      `;
      row.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('atlas-highlight-community', { detail: c.id }));
      });
      el.appendChild(row);
    }
  }

  function buildCentrality(nodes: any[]) {
    const el = document.getElementById('centrality-list')!;
    const top10 = [...nodes].sort((a, b) => b.betweenness_centrality - a.betweenness_centrality).slice(0, 10);
    const maxVal = top10[0].betweenness_centrality;

    for (const d of top10) {
      const pct = (d.betweenness_centrality / maxVal * 100).toFixed(1);
      const annotation = centralityAnnotations[d.id] || '';
      const row = document.createElement('div');
      row.className = 'bar-row';
      row.innerHTML = `
        <span class="bar-mark" style="background:${d.community_colour}"></span>
        <span class="bar-name">${d.short_name}</span>
        <span class="bar-track"><span class="bar-fill" style="width:${pct}%"></span></span>
        ${annotation ? `<span class="bar-note">${annotation}</span>` : '<span class="bar-note"></span>'}
      `;
      el.appendChild(row);
    }
  }

  function buildDyads(edges: any[], nodes: any[]) {
    const el = document.getElementById('dyads-list')!;
    const nodeMap = new Map(nodes.map((n: any) => [n.id, n]));
    const nonProtag = edges.filter(e => e.source !== 'Tyrone Slothrop' && e.target !== 'Tyrone Slothrop');
    const top10 = [...nonProtag].sort((a, b) => b.association_strength - a.association_strength).slice(0, 10);
    const maxVal = top10[0].association_strength;

    for (const d of top10) {
      const src = nodeMap.get(d.source);
      const tgt = nodeMap.get(d.target);
      const srcName = src?.short_name || d.source;
      const tgtName = tgt?.short_name || d.target;
      const pct = (d.association_strength / maxVal * 100).toFixed(1);
      const warmth = d.association_strength / maxVal;
      const colour = d3.interpolateYlOrRd(0.25 + warmth * 0.55);

      const row = document.createElement('div');
      row.className = 'dyad-row';
      row.innerHTML = `
        <span class="dyad-pair">${srcName} — ${tgtName}</span>
        <span class="dyad-track"><span class="dyad-fill" style="width:${pct}%;background:${colour}"></span></span>
        <span class="dyad-eps">${d.shared_episode_count} eps</span>
      `;
      el.appendChild(row);
    }
  }
</script>

<style>
  .plate-head {
    margin-bottom: var(--space-lg);
  }

  .plate-num {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .plate-title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    margin-top: 0.2rem;
  }

  /* --- Grid --- */
  .arch-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 64rem) {
    .arch-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: var(--space-xl);
    }
  }

  .arch-panel {
    min-width: 0;
  }

  .panel-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: var(--space-md);
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .panel-letter {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-style: italic;
    color: var(--color-accent);
  }

  .panel-label {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .panel-sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    flex-basis: 100%;
  }

  /* --- Community entries --- */
  .community-list {
    display: flex;
    flex-direction: column;
  }

  .community-entry {
    display: flex;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--color-border-subtle);
    cursor: pointer;
    transition: background 0.15s;
  }

  .community-entry:hover {
    background: rgba(255, 255, 255, 0.015);
  }

  .community-entry:last-child {
    border-bottom: none;
  }

  .community-entry :global(.c-mark) {
    width: 3px;
    flex-shrink: 0;
    border-radius: 1px;
    align-self: stretch;
  }

  .community-entry :global(.c-body) {
    flex: 1;
    min-width: 0;
  }

  .community-entry :global(.c-head) {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .community-entry :global(.c-num) {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-text-dim);
    min-width: 1.3rem;
  }

  .community-entry :global(.c-label) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    flex: 1;
  }

  .community-entry :global(.c-count) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-dim);
  }

  .community-entry :global(.c-anchors) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    margin-top: 0.15rem;
    padding-left: 1.7rem;
  }

  /* --- Bar/stat rows --- */
  .stat-list {
    display: flex;
    flex-direction: column;
  }

  .stat-list :global(.bar-row) {
    display: grid;
    grid-template-columns: 3px 5.5rem 1fr;
    gap: 0.5rem;
    align-items: center;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .stat-list :global(.bar-row:last-child) {
    border-bottom: none;
  }

  .stat-list :global(.bar-mark) {
    width: 3px;
    height: 100%;
    min-height: 1.2rem;
    border-radius: 1px;
    align-self: stretch;
  }

  .stat-list :global(.bar-name) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .stat-list :global(.bar-track) {
    height: 5px;
    background: var(--color-border-subtle);
    border-radius: 1px;
  }

  .stat-list :global(.bar-fill) {
    display: block;
    height: 100%;
    background: var(--color-text-dim);
    border-radius: 1px;
  }

  .stat-list :global(.bar-note) {
    grid-column: 2 / -1;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--color-text-dim);
    text-align: right;
    line-height: 1;
    min-height: 0.9rem;
  }

  /* --- Dyad rows --- */
  .stat-list :global(.dyad-row) {
    display: grid;
    grid-template-columns: 9rem 1fr 3rem;
    gap: 0.5rem;
    align-items: center;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .stat-list :global(.dyad-row:last-child) {
    border-bottom: none;
  }

  .stat-list :global(.dyad-pair) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .stat-list :global(.dyad-track) {
    height: 5px;
    background: var(--color-border-subtle);
    border-radius: 1px;
  }

  .stat-list :global(.dyad-fill) {
    display: block;
    height: 100%;
    border-radius: 1px;
  }

  .stat-list :global(.dyad-eps) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    text-align: right;
  }
</style>
