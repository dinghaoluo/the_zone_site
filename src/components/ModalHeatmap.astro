---
import unifiedData from "../data/phase_3a_unified_episode_data_public.json";

const MODE_LABELS: Record<string, string> = {
  M01_science_control: "Science / Control",
  M02_pop_song_comedy: "Song / Comedy",
  M03_film_media_performance: "Film / Media",
  M04_language_allusion: "Language / Allusion",
  M05_occult_divination: "Occult / Divination",
  M06_corporate_military_web: "Corporate-Military",
  M07_terminal_rocket_afterlife_descent: "Rocket / Descent",
  M08_elect_preterite_theology: "Theology",
  M09_sexuality_domination: "Sexuality",
  M10_waste_residue_body_grotesque: "Waste / Body",
};

const MODE_KEYS = Object.keys(MODE_LABELS);
const episodes = (unifiedData as any[]).sort((a, b) => a.global_index - b.global_index);

const COL_W = 14;
const COL_GAP = 2;
const ROW_H = 58;
const LABEL_W = 130;
const PAD_TOP = 36;
const PAD_BOTTOM = 40;
const LEGEND_H = 32;
const TOTAL_W = LABEL_W + episodes.length * (COL_W + COL_GAP);
const TOTAL_H = PAD_TOP + MODE_KEYS.length * ROW_H + PAD_BOTTOM + LEGEND_H;

const INTENSITY_OPACITY = [0.04, 0.3, 0.6, 1.0];

const MODE_COLORS: Record<string, string> = {
  M01_science_control: "var(--mode-science)",
  M02_pop_song_comedy: "var(--mode-comedy)",
  M03_film_media_performance: "var(--mode-film)",
  M04_language_allusion: "var(--mode-language)",
  M05_occult_divination: "var(--mode-occult)",
  M06_corporate_military_web: "var(--mode-corporate)",
  M07_terminal_rocket_afterlife_descent: "var(--mode-rocket)",
  M08_elect_preterite_theology: "var(--mode-theology)",
  M09_sexuality_domination: "var(--mode-sexuality)",
  M10_waste_residue_body_grotesque: "var(--mode-waste)",
};

interface Cell {
  x: number;
  y: number;
  w: number;
  h: number;
  opacity: number;
  fill: string;
  epId: string;
  mode: string;
  intensity: number;
}

const cellH = 44;
const cells: Cell[] = [];
for (let ci = 0; ci < episodes.length; ci++) {
  const ep = episodes[ci];
  const x = LABEL_W + ci * (COL_W + COL_GAP);
  const modes = ep.modes || {};
  for (let ri = 0; ri < MODE_KEYS.length; ri++) {
    const mk = MODE_KEYS[ri];
    const val = modes[mk]?.intensity || 0;
    if (val === 0) continue;
    const cy = PAD_TOP + ri * ROW_H + (ROW_H - cellH) / 2;
    cells.push({
      x: x + 0.5, y: cy, w: COL_W - 1, h: cellH,
      opacity: INTENSITY_OPACITY[val],
      fill: MODE_COLORS[mk],
      epId: ep.episode_id,
      mode: MODE_LABELS[mk],
      intensity: val,
    });
  }
}

const PART_BOUNDS = [
  { after: '1.21', before: '2.01' },
  { after: '2.08', before: '3.01' },
  { after: '3.32', before: '4.01' },
];
const partBoundaries: { x: number; label: string }[] = [];
const partLabels = ['I', 'II', 'III', 'IV'];
const partStarts = [0, 21, 29, 61];

for (const b of PART_BOUNDS) {
  const ai = episodes.findIndex((e: any) => e.episode_id === b.after);
  const bi = episodes.findIndex((e: any) => e.episode_id === b.before);
  if (ai >= 0 && bi >= 0) {
    const ax = LABEL_W + ai * (COL_W + COL_GAP) + COL_W + COL_GAP;
    const bx = LABEL_W + bi * (COL_W + COL_GAP);
    partBoundaries.push({ x: (ax + bx) / 2, label: '' });
  }
}

const partLabelPositions = partStarts.map((start, i) => {
  const end = i < partStarts.length - 1 ? partStarts[i + 1] : episodes.length;
  const mid = Math.floor((start + end) / 2);
  return {
    x: LABEL_W + mid * (COL_W + COL_GAP) + COL_W / 2,
    label: partLabels[i],
  };
});

const HINGE_IDS = new Set(["1.01","1.04","1.14","2.01","3.01","3.11","3.22","3.29","4.05","4.12"]);
const LEGEND_Y = PAD_TOP + MODE_KEYS.length * ROW_H + PAD_BOTTOM;
const LEGEND_ITEMS = [
  { label: 'Low', opacity: INTENSITY_OPACITY[1] },
  { label: 'Medium', opacity: INTENSITY_OPACITY[2] },
  { label: 'High', opacity: INTENSITY_OPACITY[3] },
];
---

<div class="modal-heatmap-wrap">
  <svg
    class="modal-heatmap"
    viewBox={`0 0 ${TOTAL_W} ${TOTAL_H}`}
    preserveAspectRatio="xMinYMid meet"
    role="img"
    aria-label="Emotional and intellectual currents across seventy-three episodes"
  >
    {/* Mode labels */}
    {MODE_KEYS.map((mk, ri) => (
      <text
        class="mode-label"
        x={LABEL_W - 6}
        y={PAD_TOP + ri * ROW_H + ROW_H / 2 + 3}
        text-anchor="end"
        fill={MODE_COLORS[mk]}
      >
        {MODE_LABELS[mk]}
      </text>
    ))}

    {/* Subtle row guides */}
    {MODE_KEYS.map((_, ri) => (
      <line
        x1={LABEL_W}
        y1={PAD_TOP + ri * ROW_H}
        x2={TOTAL_W}
        y2={PAD_TOP + ri * ROW_H}
        stroke="var(--color-text-dim)"
        stroke-width="0.3"
        opacity="0.15"
      />
    ))}

    {/* Part boundaries */}
    {partBoundaries.map(pb => (
      <line
        x1={pb.x} y1={PAD_TOP - 12} x2={pb.x} y2={PAD_TOP + MODE_KEYS.length * ROW_H + 6}
        stroke="var(--color-text-dim)"
        stroke-width="1"
        stroke-dasharray="4,3"
        opacity="0.35"
      />
    ))}

    {/* Part number labels along bottom */}
    {partLabelPositions.map(pl => (
      <text
        class="part-num-label"
        x={pl.x}
        y={PAD_TOP + MODE_KEYS.length * ROW_H + 20}
        text-anchor="middle"
        fill="var(--color-text-dim)"
      >
        {pl.label}
      </text>
    ))}

    {/* Hinge episode markers (small triangles at top) */}
    {episodes.map((ep: any, ci: number) => {
      if (!HINGE_IDS.has(ep.episode_id)) return null;
      const cx = LABEL_W + ci * (COL_W + COL_GAP) + COL_W / 2;
      return (
        <polygon
          points={`${cx - 4},${PAD_TOP - 16} ${cx + 4},${PAD_TOP - 16} ${cx},${PAD_TOP - 8}`}
          fill="var(--color-accent)"
          opacity="0.6"
        >
          <title>Hinge: {ep.episode_id}</title>
        </polygon>
      );
    })}

    {/* Intensity cells */}
    {cells.map(cell => (
      <rect
        x={cell.x}
        y={cell.y}
        width={cell.w}
        height={cell.h}
        rx="2.5"
        fill={cell.fill}
        opacity={cell.opacity}
      >
        <title>{cell.epId}: {cell.mode}</title>
      </rect>
    ))}

    {/* Hoverable episode columns */}
    {episodes.map((ep: any, ci: number) => {
      const isHinge = HINGE_IDS.has(ep.episode_id);
      return (
        <rect
          class={`modal-col-hit ${isHinge ? 'hinge-col' : ''}`}
          x={LABEL_W + ci * (COL_W + COL_GAP)}
          y={PAD_TOP - 12}
          width={COL_W}
          height={MODE_KEYS.length * ROW_H + 18}
          fill="transparent"
          data-ep={ep.episode_id}
          rx="1.5"
        >
          <title>{ep.episode_id}{isHinge ? ' (pivotal episode)' : ''}</title>
        </rect>
      );
    })}

    {/* Intensity legend at bottom */}
    <text
      x={LABEL_W}
      y={LEGEND_Y + 18}
      class="modal-legend-label"
      fill="var(--color-text-dim)"
    >Presence:</text>
    {LEGEND_ITEMS.map((item, i) => {
      const lx = LABEL_W + 90 + i * 90;
      return (
        <>
          <rect
            x={lx}
            y={LEGEND_Y + 6}
            width={20}
            height={20}
            rx="2.5"
            fill="var(--color-text)"
            opacity={item.opacity}
          />
          <text
            x={lx + 28}
            y={LEGEND_Y + 20}
            class="modal-legend-label"
            fill="var(--color-text-dim)"
          >{item.label}</text>
        </>
      );
    })}

    {/* Floating episode label */}
    <text
      class="modal-ep-tooltip"
      id="modal-ep-tooltip"
      x="0"
      y="0"
      text-anchor="middle"
      fill="var(--color-text)"
      opacity="0"
    ></text>
  </svg>
</div>

<script>
  {
    const wrap = document.querySelector('.modal-heatmap-wrap');
    const svg = wrap?.querySelector('.modal-heatmap') as SVGSVGElement | null;
    const tooltip = document.getElementById('modal-ep-tooltip') as SVGTextElement | null;
    const cols = wrap?.querySelectorAll('.modal-col-hit');
    const cells = wrap?.querySelectorAll('rect[rx="2.5"]');
    const labels = wrap?.querySelectorAll('.mode-label');

    if (svg && tooltip && cols) {
      cols.forEach(col => {
        col.addEventListener('mouseenter', () => {
          const ep = (col as SVGElement).dataset.ep || '';
          const cx = parseFloat(col.getAttribute('x') || '0') +
                     parseFloat(col.getAttribute('width') || '0') / 2;
          tooltip.textContent = ep;
          tooltip.setAttribute('x', String(cx));
          tooltip.setAttribute('y', String(parseFloat(col.getAttribute('y') || '0') - 6));
          tooltip.setAttribute('opacity', '1');

          col.setAttribute('fill', 'var(--color-accent)');
          col.setAttribute('opacity', '0.08');
        });

        col.addEventListener('mouseleave', () => {
          tooltip.setAttribute('opacity', '0');
          col.setAttribute('fill', 'transparent');
          col.setAttribute('opacity', '0');
        });
      });

      labels?.forEach((lbl, ri) => {
        lbl.addEventListener('mouseenter', () => {
          lbl.setAttribute('opacity', '1');
          (lbl as SVGElement).style.fontWeight = 'bold';
          cells?.forEach(cell => {
            const ry = parseFloat(cell.getAttribute('y') || '0');
            const ROW_H = 58;
            const PAD_TOP = 36;
            const cellH = 44;
            const expectedY = PAD_TOP + ri * ROW_H + (ROW_H - cellH) / 2;
            if (Math.abs(ry - expectedY) < 1) {
              cell.setAttribute('opacity', '1');
            } else {
              cell.setAttribute('opacity', '0.06');
            }
          });
        });

        lbl.addEventListener('mouseleave', () => {
          (lbl as SVGElement).style.fontWeight = '';
          cells?.forEach(cell => {
            cell.setAttribute('opacity', (cell as any)._origOpacity || cell.getAttribute('opacity') || '1');
          });
        });
      });

      cells?.forEach(cell => {
        (cell as any)._origOpacity = cell.getAttribute('opacity');
      });
    }
  }
</script>

<style>
  .modal-heatmap-wrap {
    overflow-x: visible;
    border-radius: 2px;
  }

  .modal-heatmap {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .modal-ep-tooltip {
    font-size: 10px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  .mode-label {
    font-size: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .part-num-label {
    font-size: 10px;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
  }

  .modal-legend-label {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }

  .modal-col-hit:hover {
    fill: var(--color-accent) !important;
    opacity: 0.08 !important;
  }

  .modal-col-hit.hinge-col:hover {
    opacity: 0.12 !important;
  }

  @media (max-width: 768px) {
    .modal-heatmap-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .modal-heatmap {
      width: max(100%, 800px);
      height: auto;
    }
  }
</style>
