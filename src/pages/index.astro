---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import HeroCanvas from "../components/HeroCanvas.astro";
import StructuralPreview from "../components/StructuralPreview.astro";

const base = import.meta.env.BASE_URL;

const sections = [
  {
    href: `${base}episodes/`,
    title: "Episodes",
    description:
      "Seventy-three episodes, unevenly distributed across four parts, treated as a formal sequence rather than a mere table of contents.",
  },
  {
    href: `${base}dissolution/`,
    title: "Dissolution",
    description:
      "Measures of Slothrop's dispersal and attenuation, tracing how narrative centrality frays into aliases, absence, and orbit.",
  },
  {
    href: `${base}network/`,
    title: "Network",
    description:
      "A character atlas built from episode-level co-presence, mapping density, recurrence, and the novel's shifting social geometries.",
  },
  {
    href: `${base}strands/`,
    title: "Strands",
    description:
      "Narrative strands, motifs, and handoffs arranged as structural lines through the novel rather than as isolated themes.",
  },
];
---

<Layout title="Home" description="A structural atlas of Gravity's Rainbow.">
  <Nav slot="nav" />

  <section class="hero">
    <HeroCanvas />
    <div class="container hero-inner">
      <div class="hero-copy reveal visible">
        <p class="hero-kicker">Thomas Pynchon · 1973</p>
        <h1>The Zone</h1>
        <p class="hero-subtitle">A structural atlas of <em>Gravity's Rainbow</em>.</p>
        <p class="hero-intro">
          An editorial platform for reading the novel through episodes, networks,
          dissolution, and strand geometry — computationally grounded, visually
          legible, and interpretively restrained.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href={`${base}network/`}>Explore the Network</a>
          <a class="button button-secondary" href={`${base}episodes/`}>View the Episodes</a>
        </div>
      </div>
    </div>
  </section>

  <Section id="overview">
    <div class="section-heading">
      <p class="eyebrow">Structure</p>
      <h2>Four ways into the book.</h2>
      <p>
        The site is organised around four complementary views of the novel's form,
        each designed to make a different structural pressure visible.
      </p>
    </div>

    <div class="card-grid">
      {sections.map((item) => (
        <a href={item.href} class="structure-card">
          <div class="structure-card-top">
            <span class="structure-index">0{sections.indexOf(item) + 1}</span>
            <h3>{item.title}</h3>
          </div>
          <p>{item.description}</p>
          <span class="structure-link">Enter section</span>
        </a>
      ))}
    </div>
  </Section>

  <Section id="preview">
    <div class="preview-layout">
      <div class="section-heading preview-copy">
        <p class="eyebrow">Preview</p>
        <h2>A first structural view.</h2>
        <p>
          Before the full network and episode interfaces arrive, the homepage stages
          the novel as a measurable shape: seventy-three episodes, unevenly clustered,
          with Part III expanding into the book's largest field of variation.
        </p>
      </div>
      <StructuralPreview />
    </div>
  </Section>

  <Section id="method" narrow={true}>
    <div class="method-block">
      <p class="eyebrow">Method</p>
      <h2>Computational reading, kept answerable to form.</h2>
      <p>
        The Zone combines structured textual analysis with editorial interpretation.
        It uses public-safe exports from a larger research pipeline to build visual
        models of episode scale, character presence, and narrative organisation,
        then returns those abstractions to the level of reading.
      </p>
    </div>
  </Section>

  <Footer slot="footer" />
</Layout>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 3.5rem);
    display: flex;
    align-items: center;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border-subtle);
    background:
      radial-gradient(circle at 20% 20%, rgba(196, 163, 90, 0.08), transparent 40%),
      linear-gradient(180deg, rgba(11, 11, 15, 0.92), rgba(11, 11, 15, 1));
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.5), transparent 85%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-3xl);
  }

  .hero-copy {
    max-width: 44rem;
  }

  .hero-kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 8vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.4vw, 1.9rem);
    color: var(--color-text-secondary);
    max-width: 32rem;
    margin-bottom: var(--space-lg);
  }

  .hero-intro {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text-secondary);
    max-width: 38rem;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.875rem;
    padding: 0 1.25rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .button:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .button-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #121212;
  }

  .button-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: #121212;
  }

  .button-secondary {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.02);
  }

  .button-secondary:hover {
    border-color: var(--color-accent-dim);
    color: var(--color-accent);
  }

  .section-heading {
    max-width: 40rem;
    margin-bottom: var(--space-xl);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .section-heading h2,
  .method-block h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--space-md);
  }

  .section-heading p,
  .method-block p:last-child {
    font-size: var(--text-lg);
    line-height: 1.85;
    color: var(--color-text-secondary);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-md);
  }

  .structure-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 18rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 65%),
      var(--color-surface);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      background-color 0.25s ease,
      box-shadow 0.25s ease;
    color: var(--color-text);
  }

  .structure-card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    border-color: rgba(196, 163, 90, 0.45);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
  }

  .structure-card-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .structure-index {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.12em;
  }

  .structure-card h3 {
    font-size: var(--text-2xl);
  }

  .structure-card p {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: var(--space-lg) 0;
  }

  .structure-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .preview-layout {
    display: grid;
    grid-template-columns: minmax(0, 22rem) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: start;
  }

  .preview-copy {
    margin-bottom: 0;
    padding-top: var(--space-md);
  }

  .method-block {
    text-align: left;
  }

  @media (max-width: 980px) {
    .card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .preview-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: auto;
    }

    .hero-inner {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }

    .hero-intro,
    .section-heading p,
    .method-block p:last-child {
      font-size: var(--text-base);
    }

    .card-grid {
      grid-template-columns: 1fr;
    }

    .structure-card {
      min-height: auto;
    }
  }
</style>
