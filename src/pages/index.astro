---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import HeroCanvas from "../components/HeroCanvas.astro";
import SectionIntro from "../components/SectionIntro.astro";
import StructuralPreview from "../components/StructuralPreview.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sitePath = (path: string) => `${base}/${path.replace(/^\//, '')}`;
---

<Layout title="Home" description="A visual companion to Gravity's Rainbow (1973).">
  <Nav slot="nav" />

  <section class="hero">
    <HeroCanvas />
    <div class="container hero-inner">
      <div class="hero-copy">
        <h1>The Zone</h1>
        <p class="hero-subtitle">
          A visual companion to <em>Gravity's Rainbow</em> (1973).
        </p>
        <p class="hero-intro">
          Episodes, character co-presence, Slothrop's disappearance, and
          recurring strands — drawn from a private research pipeline and
          reduced here to public-safe diagrams and notes.
        </p>
        <p class="hero-links">
          <a href={sitePath("braid/")}>Braid</a>
          <span class="hero-sep">&middot;</span>
          <a href={sitePath("dissolution/")}>Dissolution</a>
          <span class="hero-sep">&middot;</span>
          <a href={sitePath("network/")}>Network</a>
        </p>
      </div>
    </div>
  </section>

  <Section id="contents">
    <div class="section-label reveal">
      <p class="eyebrow">Contents</p>
    </div>

    <div class="reveal">
      <SectionIntro number="01" title="The Braid" href={sitePath("braid/")}>
        <p>
          Eight plotlines weaving through seventy-three episodes. Each episode
          placed in sequence, its active strands named, its structural work
          made visible.
        </p>
      </SectionIntro>
    </div>

    <div class="reveal">
      <SectionIntro number="02" title="Dissolution" href={sitePath("dissolution/")}>
        <p>
          Slothrop does not simply exit the book. His name, aliases, companions,
          and absences thin out unevenly. This view tracks that thinning as a
          sequence.
        </p>
      </SectionIntro>
    </div>

    <div class="reveal">
      <SectionIntro number="03" title="Network" href={sitePath("network/")}>
        <p>
          A co-presence map of named characters across episodes. The first
          version uses public-safe exports from the F06 character atlas.
        </p>
      </SectionIntro>
    </div>
  </Section>

  <Section id="data" narrow={true}>
    <div class="data-aside reveal">
      <div class="figure">
        <StructuralPreview />
        <p class="figure-label">Fig.&thinsp;1.&ensp;Episode word counts, left to right, grouped by part.</p>
        <p class="figure-caption">
          The longest episode is 3.11; Part&nbsp;III carries the widest range of
          episode lengths.
        </p>
      </div>
    </div>
  </Section>

  <Section id="notes" narrow={true}>
    <div class="notes-block reveal">
      <p class="eyebrow">Notes</p>
      <ol class="notes-list">
        <li>Episode boundaries follow the conventional section breaks in most
          editions. Word counts are derived from a normalised plain-text
          transcription.</li>
        <li>Only stripped, public-safe exports are used in this repository.
          The source-text corpora and proof layers remain private. See
          <a href="https://github.com/dinghaoluo/the_zone_site">the source
          repository</a> for the provenance log.<sup class="fnref"><a href="#notes">2</a></sup></li>
      </ol>
    </div>
  </Section>

  <Footer slot="footer" />
</Layout>

<style>
  .hero {
    position: relative;
    padding: var(--space-2xl) 0 var(--space-xl);
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: var(--max-width-narrow);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .hero-intro {
    font-size: var(--text-base);
    line-height: 1.85;
    color: var(--color-text-secondary);
    max-width: 34rem;
    margin-bottom: var(--space-lg);
  }

  .hero-links {
    font-size: var(--text-sm);
    line-height: 1.8;
  }

  .hero-links a {
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
  }

  .hero-links a:hover {
    color: var(--color-accent);
  }

  .hero-sep {
    color: var(--color-text-dim);
    margin: 0 0.35em;
  }

  .section-label {
    margin-bottom: var(--space-sm);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .data-aside {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }

  .figure-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.03em;
    margin-top: var(--space-md);
  }

  .figure-caption {
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
    max-width: 34rem;
  }

  .notes-block {
    padding-top: var(--space-md);
  }

  .notes-list {
    margin-top: var(--space-lg);
    padding-left: 1.5em;
    list-style: decimal;
  }

  .notes-list li {
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-dim);
    margin-bottom: var(--space-md);
  }

  .notes-list li a {
    color: var(--color-accent-dim);
  }

  .notes-list li a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-xl) 0;
    }
  }
</style>
