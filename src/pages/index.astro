---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import SectionIntro from "../components/SectionIntro.astro";
import StructuralPreview from "../components/StructuralPreview.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sitePath = (path: string) => `${base}/${path.replace(/^\//, '')}`;
---

<Layout title="Home" description="A visual companion to Gravity's Rainbow (1973).">
  <Nav slot="nav" />

  <section class="hero">
    <div class="container hero-inner">
      <h1>The Zone</h1>
      <p class="hero-subtitle">
        A visual companion to <em>Gravity's Rainbow</em>&ensp;(1973)
      </p>
      <div class="hero-rule"></div>
      <p class="hero-premise">
        Eight plotlines braided through seventy-three episodes.<br />
        A protagonist who dissolves rather than departs.<br />
        A hundred and fifty named characters, most of whom never meet.
      </p>
      <p class="hero-premise hero-premise-second">
        This site traces the novel's architecture through diagrams,
        interactive visualisations, and close readings,
        built from a private computational pipeline, reduced here to
        what can be shown without reproducing the source text.
      </p>
    </div>
  </section>

  <Section id="contents">
    <div class="section-label">
      <p class="eyebrow">Contents</p>
    </div>

    <SectionIntro number="01" title="The Braid" href={sitePath("braid/")}>
      <p>
        Eight plotlines weaving through seventy-three episodes. Each episode
        placed in sequence, its active strands named, its inner workings
        made visible.
      </p>
    </SectionIntro>

    <SectionIntro number="02" title="Scenes" href={sitePath("scenes/")}>
      <p>
        Twelve passages that readers carry out of the novel. The opening
        scream, the fairy-tale oven, P&ouml;kler at the gates of Dora,
        the last frozen instant above the Orpheus Theatre,
        each with a close reading.
      </p>
    </SectionIntro>

    <SectionIntro number="03" title="Dissolution" href={sitePath("dissolution/")}>
      <p>
        Slothrop does not simply exit the book. His name, aliases, companions,
        and absences thin out unevenly. This view tracks that thinning as a
        sequence.
      </p>
    </SectionIntro>

    <SectionIntro number="04" title="Network" href={sitePath("network/")}>
      <p>
        A co-presence map of named characters across episodes. Who appears
        with whom, when, and how the novel's social world fragments
        across its four parts.
      </p>
    </SectionIntro>
  </Section>

  <Section id="data" narrow={true}>
    <div class="data-aside reveal">
      <div class="figure">
        <StructuralPreview />
      </div>
    </div>
  </Section>

  <Section id="notes" narrow={true}>
    <div class="notes-block reveal">
      <p class="eyebrow">Notes</p>
      <ol class="notes-list">
        <li>Episode boundaries follow the conventional section breaks in most
          editions. Word counts are derived from a normalised plain-text
          transcription.</li>
        <li>Only stripped, public-safe exports are used in this repository.
          The source-text corpora and proof layers remain private. See
          <a href="https://github.com/dinghaoluo/the_zone_site">the source
          repository</a> for the provenance log.<sup class="fnref"><a href="#notes">2</a></sup></li>
      </ol>
    </div>
  </Section>

  <Footer slot="footer" />
</Layout>

<style>
  .hero {
    position: relative;
    padding: var(--space-3xl) 0 var(--space-xl);
  }

  .hero-inner {
    max-width: var(--max-width-narrow);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 7rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.5vw, 1.8rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.4;
    color: var(--color-text-secondary);
  }

  .hero-rule {
    width: 3rem;
    height: 1px;
    background: var(--color-accent-dim);
    margin: var(--space-xl) 0;
  }

  .hero-premise {
    font-family: var(--font-prose);
    font-size: var(--text-prose);
    line-height: var(--lh-prose);
    color: var(--color-text-secondary);
    max-width: 34rem;
  }

  .hero-premise-second {
    margin-top: var(--space-lg);
    color: var(--color-text-dim);
  }

  .section-label {
    margin-bottom: var(--space-sm);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .data-aside {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }

  .figure-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.03em;
    margin-top: var(--space-md);
  }

  .figure-caption {
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
    max-width: 34rem;
  }

  .notes-block {
    padding-top: var(--space-md);
  }

  .notes-list {
    margin-top: var(--space-lg);
    padding-left: 1.5em;
    list-style: decimal;
  }

  .notes-list li {
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-dim);
    margin-bottom: var(--space-md);
  }

  .notes-list li a {
    color: var(--color-accent-dim);
  }

  .notes-list li a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-xl) 0;
    }
  }
</style>
