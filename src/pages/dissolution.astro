---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
---

<Layout title="Dissolution" description="Following Slothrop through names, aliases, appearances, and absences.">
  <Nav slot="nav" />

  <Section>
    <div class="page-head reveal visible">
      <p class="eyebrow">02</p>
      <h1>Slothrop, thinning</h1>
      <div class="page-lede">
        <p>
          This section follows Slothrop through names, aliases, appearances,
          companions, and absences. The point is not to decide when he
          "disappears", but to show how unevenly the book distributes his
          disappearance.
        </p>
      </div>
    </div>
  </Section>

  <Footer slot="footer" />
</Layout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin-bottom: var(--space-xl);
  }

  .page-lede {
    max-width: var(--max-width-narrow);
  }

  .page-lede p {
    font-size: var(--text-base);
    line-height: 1.85;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
</style>
