---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
---

<Layout title="Dissolution" description="Tracking the structural disintegration of Gravity's Rainbow across its four parts.">
  <Nav slot="nav" />

  <Section>
    <p class="eyebrow">Dissolution</p>
    <h1>Slothrop dissolves.</h1>
    <p class="page-lede">
      Tracking the novel's structural disintegration — how episodes fragment,
      shorten, and multiply as the narrative moves toward the Counterforce.
    </p>
    <p class="placeholder-note">Dissolution analysis and visualisations are being prepared.</p>
  </Section>

  <Footer slot="footer" />
</Layout>

<style>
  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--space-md);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .page-lede {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text-secondary);
    max-width: 40rem;
    margin-bottom: var(--space-xl);
  }

  .placeholder-note {
    font-style: italic;
    color: var(--color-text-dim);
  }
</style>
