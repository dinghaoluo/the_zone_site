---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import DissolutionField from "../components/DissolutionField.astro";
import RocketTransfer from "../components/RocketTransfer.astro";

import aliasText from "../../public/data/base/slothrop_alias_by_episode_public.csv?raw";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

/* ── Parse alias CSV ──────────────────────────────────────── */
type AliasRow = {
  episode_id: string;
  surface_form: string;
  alias_group: string;
  share: number;
  is_canonical: boolean;
};

const aliasRows: AliasRow[] = [];
for (const line of aliasText.trim().split('\n').slice(1)) {
  const cols = line.split(',');
  aliasRows.push({
    episode_id: cols[2],
    surface_form: cols[4],
    alias_group: cols[5],
    share: parseFloat(cols[7]) || 0,
    is_canonical: cols[8] === 'yes',
  });
}

/* ── Group by episode, keep only those with alias diversity ─ */
type EpAlias = {
  episode_id: string;
  segments: { form: string; share: number; colour: string }[];
  hasAlias: boolean;
};

const ALIAS_COLOURS: Record<string, string> = {
  'Rocketman': '#c4a35a',
  'Ian Scuffling': '#6B8E6B',
  'Schwarzknabe': '#4A8B8B',
};
const CANONICAL_COLOUR = '#4A90D9';
const OTHER_ALIAS_COLOUR = '#6a6860';

const byEp = new Map();
for (const r of aliasRows) {
  if (!byEp.has(r.episode_id)) byEp.set(r.episode_id, []);
  byEp.get(r.episode_id).push(r);
}

const aliasEpisodes: EpAlias[] = [];
for (const [eid, rows] of byEp) {
  const hasAlias = rows.some((r: AliasRow) => !r.is_canonical);
  const segments = rows.map((r: AliasRow) => {
    let colour = CANONICAL_COLOUR;
    if (!r.is_canonical) {
      colour = ALIAS_COLOURS[r.surface_form] || OTHER_ALIAS_COLOUR;
    }
    return { form: r.surface_form, share: r.share, colour };
  });
  segments.sort((a: any, b: any) => (a.colour === CANONICAL_COLOUR ? -1 : 1));
  aliasEpisodes.push({ episode_id: eid, segments, hasAlias });
}

/* ── Build SVG geometry for alias timeline ────────────────── */
const TIMELINE_BAR_H = 6;
const TIMELINE_ROW_H = 16;
const TIMELINE_LABEL_W = 36;
const TIMELINE_BAR_W = 260;
const timelineH = aliasEpisodes.length * TIMELINE_ROW_H + 8;
const timelineW = TIMELINE_LABEL_W + TIMELINE_BAR_W + 4;

type BarSeg = { x: number; w: number; colour: string; form: string };
type TimelineRow = { y: number; eid: string; hasAlias: boolean; segs: BarSeg[] };

const timelineRows: TimelineRow[] = aliasEpisodes.map((ep, i) => {
  const y = 4 + i * TIMELINE_ROW_H;
  let x = TIMELINE_LABEL_W;
  const segs: BarSeg[] = ep.segments.map(s => {
    const w = s.share * TIMELINE_BAR_W;
    const seg = { x, w, colour: s.colour, form: s.form };
    x += w;
    return seg;
  });
  return { y, eid: ep.episode_id, hasAlias: ep.hasAlias, segs };
});

/* ── Part labels for annotation ───────────────────────────── */
const partStarts: { label: string; y: number }[] = [];
let lastPart = '';
for (const row of timelineRows) {
  const part = row.eid.split('.')[0];
  if (part !== lastPart) {
    partStarts.push({ label: 'Part ' + part, y: row.y });
    lastPart = part;
  }
}
---

<Layout title="Slothrop's Dissolution" description="How Gravity's Rainbow dismantles its own protagonist, from London surveillance subject to scattered Zone ghost.">
  <Nav slot="nav" />

  <main class="dissolution">
    <!-- A. PAGE HEADER -->
    <section class="page-header">
      <a class="back-link" href={`${base}/braid/`}>&larr; Back to the braid</a>
      <h1 class="page-title reveal">slothrop&rsquo;s dissolution</h1>
      <p class="page-subtitle reveal">
        The novel spends more time with Tyrone Slothrop than with anyone
        else, and then takes him apart, piece by piece, until there is
        no one left to follow.
      </p>
    </section>

    <!-- B. FRAMING PROSE -->
    <section class="reading-col">
      <div class="prose-section reveal">
        <p>
          Tyrone Slothrop begins <em>Gravity&rsquo;s Rainbow</em> as its most
          watched man. In wartime London, PISCES has him under round-the-clock
          surveillance: Teddy Bloat photographing his map, Pointsman running
          behavioural experiments, Katje Borgesius deployed as sexual bait. He
          is a body that institutions fight over, a subject pinned under so many
          gazes that the novel can barely look away from him.
        </p>
        <p>
          Then Pynchon dismantles him. The pursuit across the Riviera gives way
          to the costume changes of the Zone, Rocketman, Ian Scuffling,
          Schwarzknabe, pig hero, and each new name peels away another layer
          of the person underneath. By the final hundred pages, where Slothrop
          was there is only a rumour, a scattering, a few last sightings
          reported by people who aren&rsquo;t sure they saw him at all.
        </p>
      </div>
    </section>

    <!-- C. DISSOLUTION FIELD — INTERACTIVE -->
    <section class="interactive-plate reveal">
      <DissolutionField />
      <p class="plate-caption plate-caption-wide">
        Slothrop&rsquo;s presence across all seventy-three episodes, measured
        three ways. <em>Naming</em> tracks how often the novel names him;
        <em>Identity</em> shows when aliases begin to replace the
        given name; <em>Orbit</em> maps the companions around him. Watch
        Part&nbsp;3: the names multiply, the companions scatter, and
        &lsquo;Slothrop&rsquo; becomes just one of several things to call
        whoever this person used to be.
      </p>
    </section>

    <!-- D. THE THREE PHASES -->
    <section class="reading-col">
      <div class="prose-section reveal">
        <h2 class="section-heading">The three phases</h2>
        <p>
          In Part&nbsp;1, Slothrop is a captive subject. He lives in London under
          surveillance, eats his banana breakfasts at the NAAFI, sleeps with
          women whose names later appear on his map of V-2 strikes. Pointsman
          and the PISCES apparatus treat him as a conditioned reflex waiting to
          be decoded. Everywhere the novel looks, it finds him, because
          the institutions that govern it will not let him out of sight.
        </p>
        <p>
          Part&nbsp;2 loosens the grip. Slothrop is sent to the Riviera, ostensibly
          free but still pursued: by Katje, by the intelligence services, by
          his own compulsion to chase Imipolex G and the secret of the
          Schwarzger&auml;t. He crosses into Switzerland as Ian Scuffling, his
          first disguise, and the novel begins to hold him more loosely: still
          the protagonist, but starting to slip.
        </p>
        <p>
          Part&nbsp;3 is the long unravelling. Slothrop enters the Zone and the
          costumes come thick and fast: Rocketman in a cape made from
          a Wehrmacht flag, Schwarzknabe the black-market boy, pig hero of
          the Plechazunga. Each alias adding distance between reader and
          whatever self these names are supposed to cover. His companions
          rotate constantly: Geli Tripping, Bodine, von G&ouml;ll, Enzian in
          passing. No one stays. By the episode with Bodine and the
          Komische Oper, even the novel seems to lose track of who it is
          following. Slothrop is still named, but less and less as
          &lsquo;Slothrop&rsquo;.
        </p>
      </div>
    </section>

    <!-- E. ALIAS TIMELINE -->
    <section class="reading-col">
      <div class="alias-timeline reveal">
        <h2 class="section-heading">Identity fragmentation</h2>
        <p class="timeline-note">
          Each bar shows one episode where Slothrop appears. Blue is his
          surname; other colours mark the aliases that gradually overtake it.
        </p>

        <div class="timeline-legend">
          <span class="legend-item">
            <span class="legend-swatch" style={`background: ${CANONICAL_COLOUR}`}></span>
            Slothrop
          </span>
          <span class="legend-item">
            <span class="legend-swatch" style={`background: ${ALIAS_COLOURS['Rocketman']}`}></span>
            Rocketman
          </span>
          <span class="legend-item">
            <span class="legend-swatch" style={`background: ${ALIAS_COLOURS['Ian Scuffling']}`}></span>
            Ian Scuffling
          </span>
          <span class="legend-item">
            <span class="legend-swatch" style={`background: ${ALIAS_COLOURS['Schwarzknabe']}`}></span>
            Schwarzknabe
          </span>
        </div>

        <div class="timeline-svg-wrap">
          <svg
            class="timeline-svg"
            viewBox={`0 0 ${timelineW} ${timelineH}`}
            preserveAspectRatio="xMinYMin meet"
            role="img"
            aria-label="Alias timeline: stacked bars showing Slothrop's identity fragmentation across episodes"
          >
            {/* Part boundary annotations */}
            {partStarts.map(ps => (
              <text
                x={TIMELINE_LABEL_W + TIMELINE_BAR_W + 2}
                y={ps.y + TIMELINE_BAR_H}
                class="timeline-part-label"
                fill="var(--color-text-dim)"
              >
                {ps.label}
              </text>
            ))}

            {/* Rows */}
            {timelineRows.map(row => (
              <g class:list={['timeline-row', { 'has-alias': row.hasAlias }]}>
                {/* Episode ID label */}
                <text
                  x={TIMELINE_LABEL_W - 4}
                  y={row.y + TIMELINE_BAR_H}
                  text-anchor="end"
                  class="timeline-ep-label"
                  fill={row.hasAlias ? 'var(--color-text-secondary)' : 'var(--color-text-dim)'}
                >
                  {row.eid}
                </text>

                {/* Stacked bar segments */}
                {row.segs.map(seg => (
                  <rect
                    x={seg.x}
                    y={row.y}
                    width={Math.max(seg.w, 0.5)}
                    height={TIMELINE_BAR_H}
                    rx="1"
                    fill={seg.colour}
                    opacity={row.hasAlias ? 0.85 : 0.35}
                  >
                    <title>{seg.form}</title>
                  </rect>
                ))}
              </g>
            ))}
          </svg>
        </div>
      </div>
    </section>

    <!-- F. ROCKET TRANSFER — INTERACTIVE -->
    <section class="interactive-plate reveal">
      <RocketTransfer />
      <p class="plate-caption plate-caption-wide">
        As Slothrop dissolves through Part&nbsp;3, the novel doesn&rsquo;t
        lose a protagonist so much as redistribute one. The rocket
        plotlines, Blicero&rsquo;s assembly of the 00000 at the
        L&uuml;neburg Heath, Enzian&rsquo;s search for the 00001, Tchitcherine&rsquo;s
        parallel chase, absorb the narrative weight that Slothrop
        sheds. The book&rsquo;s centre of gravity shifts from a person
        to a trajectory: from a man being watched to a weapon being built.
      </p>
    </section>

    <!-- G. THE THEOLOGICAL TERMINUS -->
    <section class="reading-col">
      <div class="prose-section reveal">
        <h2 class="section-heading">The theological terminus</h2>
        <p>
          Part&nbsp;4 doesn&rsquo;t narrate a disappearance. The disappearance
          has already happened. Slothrop drifts through the final twelve episodes
          as a rumour and a reminiscence, glimpsed on a country road,
          mentioned by Bodine in passing, half-remembered. The one exception
          is 4.06, the novel&rsquo;s most sustained meditation on the
          Puritan theology of the preterite: the passed-over, the left-behind,
          the ones for whom no salvation was ever intended. Slothrop&rsquo;s
          scattering is reframed not as a plot event but as a condition of grace
          withheld. He was always going to be scattered. That was the point.
        </p>
        <p>
          The final episode gathers the novel&rsquo;s remaining plotlines
          in the Orpheus Theatre as the rocket descends on Los Angeles, but
          Slothrop is not among them, or is among them only as a trace, one
          voice in the hymn that the audience is invited to sing
          before the film breaks. The protagonist who began as the most
          observed man in London ends as a presence felt but not seen,
          scattered across the text like harmonics from a note that has
          already stopped sounding.
        </p>
      </div>
    </section>

    <!-- RETURN LINK -->
    <section class="reading-col">
      <div class="return-links reveal">
        <a class="return-link" href={`${base}/braid/`}>Return to braid &rarr;</a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>

<script>
  const timelineSvg = document.querySelector('.timeline-svg');
  if (timelineSvg) {
    const rows = timelineSvg.querySelectorAll('.timeline-row');
    const tooltip = document.createElement('div');
    tooltip.className = 'timeline-tooltip';
    tooltip.style.cssText = 'position:fixed;pointer-events:none;opacity:0;transition:opacity 0.15s;z-index:100;background:var(--color-surface);border:1px solid var(--color-border);border-radius:3px;padding:0.4rem 0.6rem;font-family:var(--font-mono);font-size:0.75rem;color:var(--color-text-secondary);line-height:1.5;max-width:14rem;box-shadow:0 2px 8px rgba(0,0,0,0.15)';
    document.body.appendChild(tooltip);

    let activeRow: Element | null = null;

    rows.forEach(row => {
      const rects = row.querySelectorAll('rect');
      const epLabel = row.querySelector('.timeline-ep-label');
      const eid = epLabel?.textContent?.trim() || '';

      row.addEventListener('mouseenter', (e) => {
        activeRow = row;
        row.querySelectorAll('rect').forEach(r => r.setAttribute('opacity', '1'));

        const aliases = Array.from(rects).map(r => {
          const title = r.querySelector('title');
          return title?.textContent || '';
        }).filter(Boolean);

        const unique = [...new Set(aliases)];
        tooltip.innerHTML = `<strong>${eid}</strong><br>${unique.join(' · ')}`;
        tooltip.style.opacity = '1';
      });

      row.addEventListener('mousemove', (e: Event) => {
        const me = e as MouseEvent;
        tooltip.style.left = (me.clientX + 12) + 'px';
        tooltip.style.top = (me.clientY - 8) + 'px';
      });

      row.addEventListener('mouseleave', () => {
        activeRow = null;
        const hasAlias = row.classList.contains('has-alias');
        row.querySelectorAll('rect').forEach(r => {
          r.setAttribute('opacity', hasAlias ? '0.85' : '0.35');
        });
        tooltip.style.opacity = '0';
      });
    });
  }
</script>

<style>
  .dissolution {
    padding-bottom: var(--space-2xl);
  }

  /* A. Page header */
  .page-header {
    max-width: clamp(320px, 65ch, 48rem);
    margin-inline: auto;
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-xl);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-lg);
    line-height: 1.3;
  }

  .page-subtitle {
    font-family: var(--font-prose);
    font-size: var(--text-lg);
    line-height: var(--lh-prose);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  /* Reading column */
  .reading-col {
    max-width: clamp(320px, 65ch, 48rem);
    margin-inline: auto;
    padding: 0 var(--space-lg);
  }

  .prose-section {
    padding: var(--space-xl) 0;
  }

  .prose-section p {
    font-family: var(--font-prose);
    font-size: var(--text-prose);
    line-height: var(--lh-prose);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .prose-section p:last-child {
    margin-bottom: 0;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
    line-height: 1.4;
  }

  /* Interactive plates — wider than reading column */
  .interactive-plate {
    max-width: min(90vw, 72rem);
    margin: var(--space-2xl) auto;
    padding: 0 var(--space-lg);
  }

  .plate-caption-wide {
    max-width: clamp(320px, 65ch, 48rem);
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text-dim);
    padding: 0;
  }

  /* Figure plates (kept for any remaining static use) */
  .fig-plate {
    max-width: min(90vw, 64rem);
    margin: var(--space-2xl) auto;
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .fig-plate img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }

  .plate-caption {
    max-width: clamp(320px, 65ch, 48rem);
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text-dim);
  }

  /* E. Alias timeline */
  .alias-timeline {
    padding: var(--space-xl) 0 var(--space-2xl);
    border-top: 1px solid var(--color-rule);
  }

  .timeline-note {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
  }

  .timeline-legend {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-dim);
  }

  .legend-swatch {
    display: inline-block;
    width: 10px;
    height: 6px;
    border-radius: 1px;
  }

  .timeline-svg-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .timeline-svg {
    display: block;
    width: 100%;
    max-width: 36rem;
    height: auto;
  }

  .timeline-ep-label {
    font-size: 3.5px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }

  .timeline-part-label {
    font-size: 3px;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Return link */
  .return-links {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-rule);
  }

  .return-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-dim);
    transition: color 0.2s ease;
  }

  .return-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .page-header {
      padding: var(--space-lg) var(--space-md) var(--space-xl);
    }

    .reading-col {
      padding: 0 var(--space-md);
    }

    .fig-plate {
      margin-left: calc(-1 * var(--space-md));
      margin-right: calc(-1 * var(--space-md));
      max-width: calc(100% + var(--space-md) * 2);
      transform: none;
    }

    .interactive-plate {
      padding: 0 var(--space-md);
    }

    .timeline-svg {
      width: max(100%, 320px);
    }
  }
</style>
