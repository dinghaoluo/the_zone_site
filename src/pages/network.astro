---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import NetworkAtlas from "../components/NetworkAtlas.astro";
import NetworkArchitecture from "../components/NetworkArchitecture.astro";

import nodeText from "../../public/data/step_2d/master_network_layout_nodes_public.csv?raw";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

/* ── Parse node CSV (handles quoted fields) ──────────────── */
function parseCsvLine(line: string): string[] {
  const cols: string[] = [];
  let cur = '';
  let inQuote = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"') { inQuote = !inQuote; continue; }
    if (ch === ',' && !inQuote) { cols.push(cur); cur = ''; continue; }
    cur += ch;
  }
  cols.push(cur);
  return cols;
}

type NodeRow = {
  id: string;
  short_name: string;
  community_label: string;
  community_colour: string;
  weighted_degree: number;
  degree: number;
  betweenness: number;
  total_mentions: number;
  episode_count: number;
};

const nodeLines = nodeText.trim().split('\n').slice(1);
const nodes: NodeRow[] = nodeLines.map(line => {
  const c = parseCsvLine(line);
  return {
    id: c[0],
    short_name: c[1],
    community_label: c[5],
    community_colour: c[6],
    weighted_degree: parseFloat(c[7]) || 0,
    degree: parseInt(c[8]) || 0,
    betweenness: parseFloat(c[9]) || 0,
    total_mentions: parseInt(c[12]) || 0,
    episode_count: parseInt(c[13]) || 0,
  };
});

/* ── Network statistics ──────────────────────────────────── */
const totalNodes = nodes.length;
const totalEdges = 1959;

const communityMap = new Map<string, { colour: string; count: number }>();
for (const n of nodes) {
  if (!communityMap.has(n.community_label)) {
    communityMap.set(n.community_label, { colour: n.community_colour, count: 0 });
  }
  communityMap.get(n.community_label)!.count++;
}
const totalCommunities = communityMap.size;

const byDegree = [...nodes].sort((a, b) => b.degree - a.degree);
const topNode = byDegree[0];

const byBetweenness = [...nodes].sort((a, b) => b.betweenness - a.betweenness);
---

<Layout title="Character Network" description="A co-presence map of one hundred and thirty named characters across the seventy-three episodes of Gravity's Rainbow.">
  <Nav slot="nav" />

  <main class="network-page">
    <!-- A. PAGE HEADER -->
    <section class="page-header">
      <h1 class="page-title reveal">character co&#8209;presence</h1>
      <p class="page-subtitle reveal">
        A map of who keeps turning up with whom as the novel moves from London
        to the Zone: not quite society, not quite plot, but the human weather
        through which <em>Gravity&rsquo;s Rainbow</em> passes.
      </p>
    </section>

    <!-- B. FRAMING PROSE -->
    <section class="reading-col">
      <div class="prose-section reveal">
        <p>
          This page does not claim that every pair of characters shown here
          meet face to face. What it catches is something looser and, in a novel
          like <em>Gravity&rsquo;s Rainbow</em>, often more revealing: who keeps
          being placed in the same stretch of prose, under the same pressure,
          inside the same local weather of paranoia, desire, command, or ruin.
        </p>
        <p>
          Seen this way, the character map becomes less a chart than a drift of
          social climates. London gathers one set of people around Pointsman,
          Roger, Jessica, and Pirate; the rocket system gathers another around
          Blicero, Enzian, and Gottfried; Slothrop moves between them like a
          carrier current, carrying the novel from bureaucracy to picaresque,
          from offices and laboratories into the rubble and carnival of the Zone.
        </p>
      </div>
    </section>

    <!-- C. NETWORK ARCHITECTURE — INTERACTIVE -->
    <section class="interactive-plate reveal">
      <NetworkArchitecture />
      <p class="plate-caption plate-caption-wide">
        Three ways of reading the novel&rsquo;s social field. The important thing
        is not that Slothrop touches almost everyone, but that he is not the
        only thing holding the book together. London has its own cohesion; the
        rocket world has its own grim continuity; several figures besides
        Slothrop keep the traffic moving between them.
      </p>
    </section>

    <!-- D. COMMUNITIES AND BRIDGES -->
    <section class="reading-col">
      <div class="prose-section reveal">
        <h2 class="section-heading">Communities and crossings</h2>
        <p>
          Five recognisable worlds emerge. The
          <strong style={`color: ${communityMap.get('London Counterforce')?.colour}`}>London Counterforce</strong>
          cluster gathers the White Visitation and its near-opposites:
          Pointsman, Roger Mexico, Jessica Swanlake, Pirate Prentice, the
          wartime offices, bedsits, and banana breakfasts of the early novel.
          The
          <strong style={`color: ${communityMap.get('Rocket System')?.colour}`}>Rocket System</strong>
          cluster belongs to command, sacrifice, and the weapon itself:
          Blicero, Enzian, Tchitcherine, Gottfried, and the people drawn into
          the rocket&rsquo;s wake. The large
          <strong style={`color: ${communityMap.get('Quest & Transition')?.colour}`}>Quest &amp; Transition</strong>
          group is the wandering middle of the book, where Slothrop keeps
          running into people, losing them, and moving on.
        </p>
        <p>
          Two smaller constellations sharpen the picture. The
          <strong style={`color: ${communityMap.get('Pökler Island')?.colour}`}>P&ouml;kler Island</strong>
          cluster gathers the people attached to Franz P&ouml;kler&rsquo;s
          memories: Jamf, Mondaugen, Peenem&uuml;nde, Nordhausen, the whole
          haunted chain from laboratory chemistry to Dora. It makes plain that
          P&ouml;kler&rsquo;s story is not just an isolated flashback but a sealed
          chamber of memory, engineering, and complicity inside the novel.
          The
          <strong style={`color: ${communityMap.get('Late Afterlives')?.colour}`}>Late Afterlives</strong>
          cluster belongs to the novel&rsquo;s ending, where new figures appear
          in the book&rsquo;s final drift and feel less like members of a settled
          world than remnants, witnesses, and after-echoes arriving after the
          centre has already gone.
        </p>
        <p>
          Slothrop matters here not because everything depends on him, but
          because he keeps passing between worlds. He moves from Pointsman&rsquo;s
          London to Katje&rsquo;s Riviera to the Zone&rsquo;s black markets, film sets,
          rocket ruins, and tribal arguments. Roger and Pointsman still bind the
          early book together; Blicero and Enzian keep the rocket world in grim
          alignment. What this page reveals is not a single social centre but a
          novel built out of crossings.
        </p>
      </div>
    </section>

    <!-- E. CHARACTER ATLAS — INTERACTIVE -->
    <section class="interactive-plate reveal">
      <NetworkAtlas />
      <p class="plate-caption plate-caption-wide">
        The full character atlas. Each point is a named figure in the novel,
        coloured by the world it most belongs to. Use the view controls to
        isolate Slothrop&rsquo;s crossings or the individual communities, and hover
        to see how the book clusters its people.
      </p>
    </section>

    <!-- F. NETWORK IN NUMBERS -->
    <section class="reading-col">
      <div class="prose-section reveal">
        <h2 class="section-heading">What the atlas makes plain</h2>
        <p>
          The map gathers {totalNodes} named characters into a surprisingly
          legible social field. {topNode.short_name} turns up with almost
          everyone, which confirms what any reader feels: Slothrop is the
          wanderer through whose path much of the novel passes. But the page is
          more interesting when it stops being a proof of Slothrop&rsquo;s importance
          and starts showing that the novel&rsquo;s social reality is broader than his
          path.
        </p>
        <p>
          Roger Mexico, Pointsman, Blicero, Enzian, Katje, Pirate, Jamf:
          these are not mere satellites. Each anchors a local world with its own
          temperature and grammar. Roger and Jessica belong to wartime intimacy;
          Pointsman to behavioural command; Blicero and Gottfried to sacrificial
          ritual; Enzian and the Schwarzkommando to the colonial counter-history
          of the rocket; P&ouml;kler and Jamf to memory, chemistry, and Dora.
          The novel does not keep all these people alive in the same way, but it
          keeps returning to the worlds they make.
        </p>
        <p>
          Even the small groups matter. P&ouml;kler&rsquo;s cluster tells you that
          his story is not just an isolated flashback but a whole enclave of
          memory and manufacture. The late cluster tells you that by the end of
          the book the old social world has frayed, and new presences arrive too
          late to restore it. The atlas makes that drift visible at a glance.
        </p>
      </div>
    </section>

    <!-- G. CLOSING FRAME -->
    <section class="reading-col">
      <div class="prose-section reveal">
        <h2 class="section-heading">No single centre</h2>
        <p>
          The most striking thing here is that the novel has a protagonist
          without having a single social centre. Slothrop crosses almost every
          world in the book, yet London still coheres without him, and the rocket
          world still coheres without him. Remove him and something important is
          lost, the wandering thread that keeps moving between systems, but
          not everything falls apart.
        </p>
        <p>
          That fits the novel&rsquo;s deepest intuition. <em>Gravity&rsquo;s Rainbow</em>
          is not organised like a kingdom with one throne. It is organised like
          the Zone itself: overlapping territories, temporary alliances,
          bureaucracies, rituals, black markets, old loyalties, ruined lineages.
          Every apparent centre turns out to be a crossing-point to somewhere
          else.
        </p>
      </div>
    </section>

    <!-- RETURN LINK -->
    <section class="reading-col">
      <div class="return-links reveal">
        <a class="return-link" href={`${base}/braid/`}>Return to braid &rarr;</a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>

<style>
  .network-page {
    padding-bottom: var(--space-2xl);
  }

  /* A. Page header */
  .page-header {
    max-width: clamp(320px, 65ch, 48rem);
    margin-inline: auto;
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }

  .page-subtitle {
    font-family: var(--font-prose);
    font-size: var(--text-lg);
    line-height: var(--lh-prose);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  /* Reading column */
  .reading-col {
    max-width: clamp(320px, 65ch, 48rem);
    margin-inline: auto;
    padding: 0 var(--space-lg);
  }

  .prose-section {
    padding: var(--space-xl) 0;
  }

  .prose-section p {
    font-family: var(--font-prose);
    font-size: var(--text-prose);
    line-height: var(--lh-prose);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .prose-section p:last-child {
    margin-bottom: 0;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
    line-height: 1.4;
  }

  /* Interactive plates — wider than reading column */
  .interactive-plate {
    max-width: min(90vw, 72rem);
    margin: var(--space-2xl) auto;
    padding: 0 var(--space-lg);
  }

  .plate-caption-wide {
    max-width: clamp(320px, 65ch, 48rem);
    padding: 0;
  }

  /* Figure plates (kept for any remaining static use) */
  .fig-plate {
    max-width: min(90vw, 64rem);
    margin: var(--space-2xl) auto;
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .fig-plate img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }

  .plate-caption {
    max-width: clamp(320px, 65ch, 48rem);
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text-dim);
  }

  /* Return link */
  .return-links {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-rule);
  }

  .return-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-dim);
    transition: color 0.2s ease;
  }

  .return-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .page-header {
      padding: var(--space-lg) var(--space-md) var(--space-xl);
    }

    .reading-col {
      padding: 0 var(--space-md);
    }

    .fig-plate {
      margin-left: calc(-1 * var(--space-md));
      margin-right: calc(-1 * var(--space-md));
      max-width: calc(100% + var(--space-md) * 2);
      transform: none;
    }

    .interactive-plate {
      padding: 0 var(--space-md);
    }
  }
</style>
