---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
---

<Layout title="Network" description="Mapping the social geometry of Gravity's Rainbow.">
  <Nav slot="nav" />

  <Section>
    <div class="page-head reveal visible">
      <p class="eyebrow">03</p>
      <h1>Mapping the novel's social geometry</h1>
      <div class="page-lede">
        <p>
          One hundred and thirty-eight named characters appear across the novel's
          seventy-three episodes. Some recur persistently; others surface once and
          vanish. The network page maps their co-presence — which characters share
          episodes, how frequently, and in what structural positions — to make visible
          the social architecture that the text builds and then dismantles.
        </p>
        <p>
          The underlying data is drawn from the F06 character atlas, a public-safe
          export of episode-level mention counts and co-occurrence tables. The full
          interactive network visualisation is being prepared.
        </p>
      </div>
    </div>
  </Section>

  <Footer slot="footer" />
</Layout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin-bottom: var(--space-xl);
  }

  .page-lede {
    max-width: var(--max-width-narrow);
  }

  .page-lede p {
    font-size: var(--text-base);
    line-height: 1.85;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
</style>
