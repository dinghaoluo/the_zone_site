function parseCSV(raw: string) {
  const lines = raw.trim().split('\n');
  const headers = lines[0].split(',').map((h: string) => h.trim());
  const result = new Map();
  for (let i = 1; i < lines.length; i++) {
    const vals = lines[i].split(',');
    const eid = vals[0].trim();
    const row: any = {};
    for (let j = 1; j < headers.length; j++) row[headers[j]] = parseInt(vals[j], 10) || 0;
    result.set(eid, row);
  }
  return result;
}

function parseQuotesCSV(raw: string) {
  const result = new Map();
  for (const line of raw.trim().split('\n').slice(1)) {
    const fields: string[] = [];
    let cur = '';
    let inQ = false;
    for (let ci = 0; ci < line.length; ci++) {
      const ch = line[ci];
      if (ch === '"') { inQ = !inQ; }
      else if (ch === ',' && !inQ) { fields.push(cur); cur = ''; }
      else { cur += ch; }
    }
    fields.push(cur);
    const eid = fields[0]?.trim();
    const label = fields[1]?.trim();
    const quote = fields[2]?.trim();
    const note = fields[7]?.trim();
    if (eid && quote) {
      if (!result.has(eid)) result.set(eid, []);
      result.get(eid)!.push({ label: label || '', quote, note: note || '' });
    }
  }
  return result;
}

const synopsesMap = new Map((synopsesRaw as any[]).map((s: any) => [s.episode_id, s.synopsis]));
const quotesMap = parseQuotesCSV(quotesText);
const modalMap = parseCSV(modalText);
const recurrenceMap = parseCSV(recurrenceText);

/* ── Parse 2G episode metadata ───────────────────────────── */
function parseCsvLine(line: string): string[] {
  const cols: string[] = [];
  let cur = '';
  let inQuote = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"') { inQuote = !inQuote; continue; }
    if (ch === ',' && !inQuote) { cols.push(cur); cur = ''; continue; }
    cur += ch;
  }
  cols.push(cur);
  return cols;
}

