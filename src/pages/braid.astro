        ))}

        <figure class="fig-plate reveal">
          <RecurrenceHeatmap />
          <figcaption class="plate-caption">
            Historical violence enters the novel in concentrated bursts, not
            as background. Most episodes carry none at all. When it arrives,
            the Herero genocide in 3.03 and 3.22, the Dora forced-labour
            tunnels in 3.11, the Holocaust running silently beneath
            Pökler&rsquo;s family visits, it transforms everything around it.
            The long silences between these eruptions are part of the argument:
            the reader crosses stretches of forgetting before each return of
            what cannot be forgotten.
          </figcaption>
        </figure>

        {p3b.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="3">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
            </header>
            {ep.meta && (
              <p class="ep-setting">{ep.meta.time}, {ep.meta.location} · {ep.meta.focalisation}</p>
            )}
            <p class="ep-synopsis" set:html={ep.synopsis} />
            {ep.hingeCommentary && (
              <div class="hinge-commentary">
                <p>{ep.hingeCommentary}</p>
              </div>
            )}
            {ep.quotes.length > 0 && (
              <div class="quote-block">
                {ep.quotes.map((q: { label: string; quote: string; note: string }) => (
                  <blockquote class="pull-quote">
                    {q.label && <span class="quote-anchor-label">{q.label}</span>}
                    <p>&lsquo;{q.quote}&rsquo;</p>
                  </blockquote>
                ))}
              </div>
            )}
            {ep.hingeAtmosphere && (
              <p class="hinge-atmosphere">{ep.hingeAtmosphere}</p>
            )}
            {ep.annotations.length > 0 && (
              <aside class="sidenotes">
                {ep.annotations.map((a: Annotation) => (
                  <div class="sidenote">
                    <p class="sidenote-text">{a.text}</p>
                    {a.url ? (
                      <a class="sidenote-source" href={a.url} target="_blank" rel="noopener">{a.source}</a>
                    ) : a.page ? (
                      <a class="sidenote-source sidenote-internal" href={`${base}${a.page}`}>{a.source}</a>
                    ) : (
                      <span class="sidenote-source">{a.source}</span>
                    )}
                  </div>
                ))}
              </aside>
            )}
          </article>
        ))}

        <div class="part-transition reveal">
          <p>
            Twelve episodes. Everything that scattered in Part 3 now converges
            or extinguishes. Blicero fires the 00000 with Gottfried inside.
            Enzian&rsquo;s Schwarzkommando assemble and fire the 00001. Roger
            Mexico disrupts a Krupp dinner with filth poetry and is absorbed
            by the system he fought. Geli Tripping&rsquo;s love-spell dissolves
            Tchitcherine&rsquo;s pursuit into unrecognition. Slothrop disperses
            beyond recovery. In a Los Angeles cinema, the rocket descends
            toward the audience.
          </p>
        </div>

        <figure class="fig-plate reveal">
          <ConvergencePlate />
          <figcaption class="plate-caption">
            Part 4 reverses Part 3&rsquo;s scattering. Characters who ran
            independently for hundreds of pages now collapse toward the final
            episode: Blicero&rsquo;s sacrifice, Enzian&rsquo;s counter-rocket,
            Slothrop&rsquo;s scattered American traces, the Orpheus Theatre&rsquo;s
            darkened screen. The Counterforce flares early and fades;
            Pökler and Pointsman are already gone. What converges is not
            resolution but accumulation; the novel tightens into a knot
            it never unties.
          </figcaption>
        </figure>

        {p4.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="4">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
            </header>
            {ep.meta && (
              <p class="ep-setting">{ep.meta.time}, {ep.meta.location} · {ep.meta.focalisation}</p>
            )}
            <p class="ep-synopsis" set:html={ep.synopsis} />
            {ep.hingeCommentary && (
              <div class="hinge-commentary">
                <p>{ep.hingeCommentary}</p>
              </div>
            )}
            {ep.quotes.length > 0 && (
              <div class="quote-block">
                {ep.quotes.map((q: { label: string; quote: string; note: string }) => (
                  <blockquote class="pull-quote">
                    {q.label && <span class="quote-anchor-label">{q.label}</span>}
                    <p>&lsquo;{q.quote}&rsquo;</p>
                  </blockquote>
                ))}
              </div>
            )}
            {ep.hingeAtmosphere && (
              <p class="hinge-atmosphere">{ep.hingeAtmosphere}</p>
            )}
            {ep.annotations.length > 0 && (
              <aside class="sidenotes">
                {ep.annotations.map((a: Annotation) => (
                  <div class="sidenote">
                    <p class="sidenote-text">{a.text}</p>
                    {a.url ? (
                      <a class="sidenote-source" href={a.url} target="_blank" rel="noopener">{a.source}</a>
                    ) : a.page ? (
                      <a class="sidenote-source sidenote-internal" href={`${base}${a.page}`}>{a.source}</a>
                    ) : (
                      <span class="sidenote-source">{a.source}</span>
                    )}
                  </div>
                ))}
              </aside>
            )}
          </article>
        ))}
      </div>
    </div>
  </main>

  <!-- Plotline arc slide-out panels -->
  <div class="arc-overlay" id="arc-overlay" aria-hidden="true"></div>
  {plotlineArcs.map(arc => (
    <aside class="arc-panel" id={`arc-${arc.id}`} aria-hidden="true">
      <div class="arc-panel-inner">
        <button class="arc-close" type="button" aria-label="Close">&times;</button>
        <h2 class="arc-title">{arc.label}</h2>
        <div class="arc-body">
          {arc.paragraphs.map((p: string) => (
            <p>{p}</p>
          ))}
          {arc.id === 'P01' && (
            <p class="arc-deepdive">
              <a href={`${base}/dissolution/`}>Deep-dive: Slothrop&rsquo;s dissolution &rarr;</a>
            </p>
          )}
        </div>
      </div>
    </aside>
  ))}

  <Footer slot="footer" />
</Layout>

<script>
  const panels = document.querySelectorAll('.ep-panel');
  const fill = document.getElementById('scroll-fill');
  const partLabel = document.getElementById('scroll-part-label');
  const braidSvg = document.querySelector('.braid-viz') as SVGElement | null;
  const cursor = document.getElementById('braid-cursor') as SVGRectElement | null;
  const total = panels.length;
  let lastVisible = -1;
  let currentPart = '1';
  let cursorLocked = false;
  let scrollEndTimer: ReturnType<typeof setTimeout> | null = null;

  // Build episode-id → column-index lookup from hit areas
  const colHits = document.querySelectorAll('.braid-col-hit');
  const epIdToIdx = new Map<string, number>();
  colHits.forEach((el, i) => {
    const eid = (el as SVGElement).dataset.ep;
    if (eid) epIdToIdx.set(eid, i);
  });

  function updateCursor(idx: number) {
    if (cursorLocked) return;
    if (!cursor || !braidSvg || idx < 0) return;
    const hit = colHits[idx] as SVGRectElement | undefined;
    if (!hit) return;
    cursor.setAttribute('x', hit.getAttribute('x') || '0');
    cursor.setAttribute('opacity', '0.18');
    braidSvg.classList.add('cursor-active');
  }

  function clearCursor() {
    if (cursorLocked) return;
    if (cursor) cursor.setAttribute('opacity', '0');
    braidSvg?.classList.remove('cursor-active');
  }

  function forceSetCursor(idx: number) {
    if (!cursor || !braidSvg || idx < 0) return;
    const hit = colHits[idx] as SVGRectElement | undefined;
    if (!hit) return;
    cursor.setAttribute('x', hit.getAttribute('x') || '0');
    cursor.setAttribute('opacity', '0.18');
    braidSvg.classList.add('cursor-active');
  }

  function unlockCursorOnScrollEnd() {
    if (scrollEndTimer) clearTimeout(scrollEndTimer);
    scrollEndTimer = setTimeout(() => {
      cursorLocked = false;
      // After unlock, find the actual episode at the current scroll position
      // by checking which panel's top edge is closest to just below the header
      const header = document.getElementById('braid-header');
      const nav = document.querySelector('.nav') as HTMLElement | null;
      const obstruction = (nav ? nav.offsetHeight : 0) + (header ? header.offsetHeight : 0) + 20;
      let bestIdx = lastVisible;
      let bestDist = Infinity;
      panels.forEach((p, i) => {
        const rect = p.getBoundingClientRect();
        const dist = Math.abs(rect.top - obstruction);
        if (dist < bestDist) { bestDist = dist; bestIdx = i; }
      });
      lastVisible = bestIdx;
      updateCursor(bestIdx);
      if (fill) fill.style.width = ((bestIdx + 1) / total) * 100 + '%';
    }, 200);
  }

  // Scroll tracking — forward
  const scrollObs = new IntersectionObserver((entries) => {
    let changed = false;
    entries.forEach(e => {
      if (e.isIntersecting) {
        const idx = Array.from(panels).indexOf(e.target as Element);
        if (idx > lastVisible) { lastVisible = idx; changed = true; }
        const part = (e.target as HTMLElement).dataset.part || '1';
        if (part !== currentPart) {
          currentPart = part;
          if (partLabel) partLabel.textContent = 'Part ' + part;
        }
      }
    });
    if (changed) {
      if (fill) fill.style.width = ((lastVisible + 1) / total) * 100 + '%';
      updateCursor(lastVisible);
    }
  }, { threshold: 0.3 });

  panels.forEach(p => scrollObs.observe(p));

  // Scroll tracking — backward
  const scrollObsBack = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) {
        const idx = Array.from(panels).indexOf(e.target as Element);
        if (idx === lastVisible && idx > 0) {
          lastVisible = idx - 1;
          const prev = panels[lastVisible] as HTMLElement;
          const part = prev.dataset.part || '1';
          if (part !== currentPart) {
            currentPart = part;
            if (partLabel) partLabel.textContent = 'Part ' + part;
          }
          if (fill) fill.style.width = ((lastVisible + 1) / total) * 100 + '%';
          updateCursor(lastVisible);
        }
      }
    });
  }, { threshold: 0 });

  panels.forEach(p => scrollObsBack.observe(p));

  // Clear cursor when non-episode elements (transitions, plates) are in view
  const nonEpElements = document.querySelectorAll('.part-transition, .fig-plate');
  const nonEpObs = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting && e.intersectionRatio > 0.5) {
        clearCursor();
        return;
      }
    }
  }, { threshold: 0.5 });
  nonEpElements.forEach(el => nonEpObs.observe(el));

  colHits.forEach(el => {
    el.addEventListener('click', () => {
      const eid = (el as SVGElement).dataset.ep;
      if (!eid) return;
      const target = document.getElementById('ep-' + eid);
      if (!target) return;

      const idx = epIdToIdx.get(eid);
      if (idx !== undefined) {
        cursorLocked = true;
        forceSetCursor(idx);
        lastVisible = idx;
      }

      const header = document.getElementById('braid-header');
      const nav = document.querySelector('.nav') as HTMLElement | null;
      const navH = nav ? nav.offsetHeight : 0;
      const headerH = header ? header.offsetHeight : 0;
      const obstruction = navH + headerH + 12;

      const absoluteTop = target.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({
        top: absoluteTop - obstruction,
        behavior: 'smooth',
      });

      target.classList.add('flash');
      setTimeout(() => target.classList.remove('flash'), 900);
    });
  });

  // Unlock cursor after smooth scroll finishes
  window.addEventListener('scroll', () => {
    if (cursorLocked) unlockCursorOnScrollEnd();
  }, { passive: true });

  // Click strand label → open slide-out (reuse existing mechanism)
  const overlay = document.getElementById('arc-overlay');
  let openPanelEl: HTMLElement | null = null;

  function closeArc() {
    if (openPanelEl) {
      openPanelEl.classList.remove('open');
      openPanelEl.setAttribute('aria-hidden', 'true');
      openPanelEl = null;
    }
    overlay?.classList.remove('visible');
    overlay?.setAttribute('aria-hidden', 'true');
  }

  function openArc(id: string) {
    closeArc();
    const panel = document.getElementById('arc-' + id);
    if (panel) {
      openPanelEl = panel;
      panel.classList.add('open');
      panel.setAttribute('aria-hidden', 'false');
      overlay?.classList.add('visible');
      overlay?.setAttribute('aria-hidden', 'false');
    }
  }

  // SVG strand labels open slide-outs
  document.querySelectorAll('.braid-label').forEach(lbl => {
    lbl.addEventListener('click', () => {
      const id = (lbl as SVGElement).dataset.strand;
      if (id) openArc(id);
    });
  });

  overlay?.addEventListener('click', closeArc);

  document.querySelectorAll('.arc-close').forEach(btn => {
    btn.addEventListener('click', closeArc);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && openPanelEl) closeArc();
  });
</script>

