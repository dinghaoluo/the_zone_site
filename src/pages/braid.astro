---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

import synopsesRaw from "../data/episode_synopses.json";
import unifiedData from "../data/phase_3a_unified_episode_data_public.json";
import quotesText from "../data/episode_anchor_quotes_APPROVED_PUBLIC.csv?raw";
import modalText from "../../public/data/step_3a/phase_3a_modal_intensity_matrix_public.csv?raw";
import recurrenceText from "../../public/data/step_3a/phase_3a_recurrence_intensity_matrix_public.csv?raw";
import plotlineArcsRaw from "../data/plotline_arc_descriptions.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function parseCSV(raw: string) {
  const lines = raw.trim().split('\n');
  const headers = lines[0].split(',').map((h: string) => h.trim());
  const result = new Map();
  for (let i = 1; i < lines.length; i++) {
    const vals = lines[i].split(',');
    const eid = vals[0].trim();
    const row: any = {};
    for (let j = 1; j < headers.length; j++) row[headers[j]] = parseInt(vals[j], 10) || 0;
    result.set(eid, row);
  }
  return result;
}

function parseQuotesCSV(raw: string) {
  const result = new Map();
  for (const line of raw.trim().split('\n').slice(1)) {
    const fields: string[] = [];
    let cur = '';
    let inQ = false;
    for (let ci = 0; ci < line.length; ci++) {
      const ch = line[ci];
      if (ch === '"') { inQ = !inQ; }
      else if (ch === ',' && !inQ) { fields.push(cur); cur = ''; }
      else { cur += ch; }
    }
    fields.push(cur);
    const eid = fields[0]?.trim();
    const quote = fields[2]?.trim();
    const note = fields[7]?.trim();
    if (eid && quote) {
      if (!result.has(eid)) result.set(eid, []);
      result.get(eid)!.push({ quote, note: note || '' });
    }
  }
  return result;
}

const synopsesMap = new Map((synopsesRaw as any[]).map((s: any) => [s.episode_id, s.synopsis]));
const quotesMap = parseQuotesCSV(quotesText);
const modalMap = parseCSV(modalText);
const recurrenceMap = parseCSV(recurrenceText);

const PL: any = {
  P01: "Slothrop pursuit",
  P02: "Blicero triad",
  P03: "Schwarzkommando",
  P04: "Pökler / Imipolex",
  P05: "White Visitation",
  P06: "Counterforce",
  P07: "Tchitcherine",
  P08: "film-body-image",
};

const ML: any = {
  M01_science_control: "Science / Control",
  M02_pop_song_comedy: "Comedy / Song",
  M03_film_media_performance: "Film / Performance",
  M04_language_allusion: "Language / Allusion",
  M05_occult_divination: "Occult / Divination",
  M06_corporate_military_web: "Corporate-Military",
  M07_terminal_rocket_afterlife_descent: "Rocket / Terminal",
  M08_elect_preterite_theology: "Theology / Preterition",
  M09_sexuality_domination: "Sexuality / Domination",
  M10_waste_residue_body_grotesque: "Waste / Grotesque",
};

const RL: any = {
  species_extinction: "Species Extinction",
  colonial_genocide: "Colonial Genocide",
  holocaust_absence_or_adjacency: "Holocaust Adjacency",
  forced_labour_industrial_body_processing: "Forced Labour",
  postwar_technocratic_continuation: "Technocratic Continuation",
};

const HINGES = new Set(["1.01","1.04","1.14","2.01","3.01","3.11","3.22","3.29","4.05","4.12"]);

const STRAND_LABELS = [
  { id: "P01", short: "Slothrop" },
  { id: "P02", short: "Blicero" },
  { id: "P03", short: "Enzian" },
  { id: "P04", short: "Pökler" },
  { id: "P05", short: "Pointsman" },
  { id: "P06", short: "Counterforce" },
  { id: "P07", short: "Tchitcherine" },
  { id: "P08", short: "Film/Body" },
];

const plotlineArcs = (plotlineArcsRaw as any[]).map((a: any) => ({
  id: a.plotline_id,
  label: a.label,
  paragraphs: a.arc_description.split('\n\n'),
}));

type Ep = {
  id: string; part: number; isHinge: boolean;
  synopsis: string; strands: string;
  quotes: { quote: string; note: string }[];
  atmosphere: string; registers: string;
};

const episodes: Ep[] = unifiedData.map((u: any) => {
  const strands = Object.entries(u.plotlines || {})
    .filter(([_, v]: [string, any]) => (v as any).intensity >= 1)
    .map(([k, v]: [string, any]) => {
      const p = k.match(/^(P\d+)/)?.[1] || '';
      const fn = (v as any).function || 'active';
      return PL[p] + ' (' + fn + ')';
    });

  const mRow = modalMap.get(u.episode_id) || {};
  const modes = Object.entries(mRow)
    .filter(([_, v]) => (v as number) >= 2)
    .map(([k]) => ML[k] || k);

  const rRow = recurrenceMap.get(u.episode_id) || {};
  const regs = Object.entries(rRow)
    .filter(([_, v]) => (v as number) >= 1)
    .map(([k]) => RL[k] || k);

  return {
    id: u.episode_id,
    part: u.part,
    isHinge: HINGES.has(u.episode_id),
    synopsis: synopsesMap.get(u.episode_id) || '',
    strands: strands.length ? 'Active strands: ' + strands.join(', ') + '.' : '',
    quotes: quotesMap.get(u.episode_id) || [],
    atmosphere: modes.length ? 'Atmosphere: ' + modes.join(', ') + '.' : '',
    registers: regs.length ? 'Historical registers: ' + regs.join(', ') + '.' : '',
  };
});

const p1 = episodes.filter((e: Ep) => e.part === 1);
const p2 = episodes.filter((e: Ep) => e.part === 2);
const p3a = episodes.filter((e: Ep) => e.part === 3 && parseInt(e.id.split('.')[1]) <= 10);
const p3b = episodes.filter((e: Ep) => e.part === 3 && parseInt(e.id.split('.')[1]) > 10);
const p4 = episodes.filter((e: Ep) => e.part === 4);
---

<Layout title="The Braid" description="Eight plotlines braiding through seventy-three episodes.">
  <Nav slot="nav" />

  <main class="braid">
    <section class="braid-intro">
      <p class="intro-text reveal">
        <em>Gravity&rsquo;s Rainbow</em> is a braid. Eight plotlines &mdash; pursuit,
        sacrifice, counter-text, complicity, control, love, counter-line, and
        image &mdash; weave through seventy-three episodes across four parts,
        thickening where they govern structure, thinning where they yield. What
        follows is the novel read as that braid: each episode placed in
        sequence, its active strands named, its structural work made visible.
        Scroll as you would read.
      </p>
    </section>

    <div class="braid-scroll">
      <div class="braid-header" id="braid-header">
        <div class="braid-header-inner">
          <img
            src={`${base}/figures/step_3a/F01_plotline_braid.png`}
            alt="Eight plotlines braiding across seventy-three episodes"
          />
        </div>
        <nav class="strand-nav" aria-label="Plotline arcs">
          {STRAND_LABELS.map(s => (
            <button class="strand-btn" data-strand={s.id} type="button">
              {s.short}
            </button>
          ))}
        </nav>
        <div class="scroll-track">
          <span class="scroll-part-label" id="scroll-part-label">Part 1</span>
          <div class="scroll-bar">
            <div class="scroll-ticks">
              <span class="tick" style="left: 28.77%"></span>
              <span class="tick" style="left: 39.73%"></span>
              <span class="tick" style="left: 83.56%"></span>
            </div>
            <div class="scroll-fill" id="scroll-fill"></div>
          </div>
        </div>
      </div>

      <div class="reading-col">
        {p1.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="1">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}

        <div class="part-transition reveal">
          <p>
            Part 1 ends with all eight strands established but unevenly
            weighted &mdash; Slothrop&rsquo;s pursuit and the White Visitation&rsquo;s control
            machinery dominate, while Enzian&rsquo;s counter-text and Tchitcherine&rsquo;s
            Soviet line remain subterranean. Part 2 compresses to eight episodes
            and shifts the structural engine: Slothrop moves south into the
            Zone&rsquo;s threshold, Pointsman&rsquo;s apparatus strains toward its
            operational peak, and the Blicero triad receives its founding
            backstory. The braid tightens before the Zone blows it open.
          </p>
        </div>

        {p2.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="2">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}

        <div class="part-transition reveal">
          <p>
            Part 3 is the explosion. Thirty-two episodes &mdash; nearly half the
            novel &mdash; scatter across the Zone&rsquo;s dissolved geography. Slothrop
            fragments into aliases; Enzian&rsquo;s Schwarzkommando and Tchitcherine&rsquo;s
            counter-line claim structural weight they never had before; the
            film-body-image strand surges through the Anubis sequence; and five
            plotlines compete for architectural command where Part 1 gave that
            authority to one or two. The braid doesn&rsquo;t loosen &mdash; it multiplies.
          </p>
        </div>

        <figure class="fig-plate reveal">
          <img
            src={`${base}/figures/step_3a/F03_modal_atmosphere.png`}
            alt="Modal atmosphere heatmap across seventy-three episodes"
            loading="lazy"
          />
          <figcaption class="plate-caption">
            The novel&rsquo;s episodes are not only driven by plotlines but saturated
            by modal atmospheres &mdash; registers of science, comedy, film, theology,
            sexuality, and violence that shift, peak, and recombine independently
            of the character-driven strands.
          </figcaption>
        </figure>

        {p3a.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="3">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}

        <figure class="fig-plate reveal">
          <img
            src={`${base}/figures/step_3a/F04_historical_recurrence.png`}
            alt="Historical recurrence registers pulsing through specific structural nodes"
            loading="lazy"
          />
          <figcaption class="plate-caption">
            Historical violence is not uniformly distributed across the novel
            but pulses through specific structural nodes. Fifty-nine of
            seventy-three episodes carry no recurrence register at all.
          </figcaption>
        </figure>

        {p3b.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="3">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}

        <div class="part-transition reveal">
          <p>
            Twelve episodes. Everything that scattered in Part 3 now converges
            or extinguishes. Blicero&rsquo;s 00000 and Enzian&rsquo;s 00001 reach maximum
            intensity simultaneously. The Counterforce fails, then mourns.
            Slothrop scatters beyond recovery into theological trace. And the
            Orpheus Theatre fuses rocket, film, and congregation into a single
            suspended instant.
          </p>
        </div>

        <figure class="fig-plate reveal">
          <img
            src={`${base}/figures/step_3a/F02_terminal_convergence.png`}
            alt="Part 4 convergence pattern showing plotlines collapsing toward the final episode"
            loading="lazy"
          />
          <figcaption class="plate-caption">
            Part 4&rsquo;s convergence pattern. Plotlines that ran separately for
            hundreds of pages now collapse toward the final episode.
          </figcaption>
        </figure>

        {p4.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="4">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}
      </div>
    </div>
  </main>

  <!-- Plotline arc slide-out panels -->
  <div class="arc-overlay" id="arc-overlay" aria-hidden="true"></div>
  {plotlineArcs.map(arc => (
    <aside class="arc-panel" id={`arc-${arc.id}`} aria-hidden="true">
      <div class="arc-panel-inner">
        <button class="arc-close" type="button" aria-label="Close">&times;</button>
        <h2 class="arc-title">{arc.label}</h2>
        <div class="arc-body">
          {arc.paragraphs.map((p: string) => (
            <p>{p}</p>
          ))}
        </div>
      </div>
    </aside>
  ))}

  <Footer slot="footer" />
</Layout>

<script>
  // Scroll tracking
  const panels = document.querySelectorAll('.ep-panel');
  const fill = document.getElementById('scroll-fill');
  const partLabel = document.getElementById('scroll-part-label');
  const total = panels.length;
  let lastVisible = 0;
  let currentPart = '1';

  const scrollObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const idx = Array.from(panels).indexOf(e.target as Element);
        if (idx > lastVisible) lastVisible = idx;
        const part = (e.target as HTMLElement).dataset.part || '1';
        if (part !== currentPart) {
          currentPart = part;
          if (partLabel) partLabel.textContent = 'Part ' + part;
        }
      }
    });
    if (fill) {
      const pct = ((lastVisible + 1) / total) * 100;
      fill.style.width = pct + '%';
    }
  }, { threshold: 0.3 });

  panels.forEach(p => scrollObs.observe(p));

  // Also track scroll backward
  const scrollObsBack = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) {
        const idx = Array.from(panels).indexOf(e.target as Element);
        if (idx === lastVisible && idx > 0) {
          lastVisible = idx - 1;
          const prev = panels[lastVisible] as HTMLElement;
          const part = prev.dataset.part || '1';
          if (part !== currentPart) {
            currentPart = part;
            if (partLabel) partLabel.textContent = 'Part ' + part;
          }
          if (fill) fill.style.width = ((lastVisible + 1) / total) * 100 + '%';
        }
      }
    });
  }, { threshold: 0 });

  panels.forEach(p => scrollObsBack.observe(p));

  // Plotline arc slide-out
  const overlay = document.getElementById('arc-overlay');
  const strandBtns = document.querySelectorAll('.strand-btn');
  let openPanel: HTMLElement | null = null;

  function closeArc() {
    if (openPanel) {
      openPanel.classList.remove('open');
      openPanel.setAttribute('aria-hidden', 'true');
      openPanel = null;
    }
    overlay?.classList.remove('visible');
    overlay?.setAttribute('aria-hidden', 'true');
  }

  function openArc(id: string) {
    closeArc();
    const panel = document.getElementById('arc-' + id);
    if (panel) {
      openPanel = panel;
      panel.classList.add('open');
      panel.setAttribute('aria-hidden', 'false');
      overlay?.classList.add('visible');
      overlay?.setAttribute('aria-hidden', 'false');
    }
  }

  strandBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.strand;
      if (id) openArc(id);
    });
  });

  overlay?.addEventListener('click', closeArc);

  document.querySelectorAll('.arc-close').forEach(btn => {
    btn.addEventListener('click', closeArc);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && openPanel) closeArc();
  });
</script>

<style>
  .braid {
    padding-bottom: var(--space-2xl);
  }

  .braid-intro {
    max-width: clamp(320px, 65ch, 48rem);
    margin-inline: auto;
    padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
  }

  .intro-text {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    line-height: 1.85;
    color: var(--color-text-secondary);
  }

  .braid-header {
    position: sticky;
    top: 3.5rem;
    z-index: 10;
    background: var(--color-bg);
    padding: 0 var(--space-lg) 0;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .braid-header-inner {
    overflow: hidden;
    border-radius: 2px;
  }

  .braid-header-inner img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Strand navigation */
  .strand-nav {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    padding: var(--space-sm) 0;
  }

  .strand-btn {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.2em 0.5em;
    border-radius: 2px;
    opacity: 0.7;
    transition: opacity 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .strand-btn:hover {
    opacity: 1;
    color: var(--color-accent);
    background: rgba(196, 163, 90, 0.08);
  }

  /* Scroll progress track */
  .scroll-track {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-bottom: var(--space-sm);
  }

  .scroll-part-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    white-space: nowrap;
    min-width: 3.5em;
  }

  .scroll-bar {
    flex: 1;
    height: 2px;
    background: var(--color-border);
    position: relative;
    border-radius: 1px;
  }

  .scroll-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: var(--color-accent-dim);
    border-radius: 1px;
    transition: width 0.3s ease;
  }

  .scroll-ticks {
    position: absolute;
    inset: 0;
  }

  .tick {
    position: absolute;
    top: -2px;
    width: 1px;
    height: 6px;
    background: var(--color-text-dim);
    opacity: 0.5;
  }

  .braid-header::after {
    content: '';
    position: absolute;
    bottom: -1.5rem;
    left: 0;
    right: 0;
    height: 1.5rem;
    background: linear-gradient(to bottom, var(--color-bg), transparent);
    pointer-events: none;
  }

  /* Reading column — responsive prose width */
  .reading-col {
    position: relative;
    max-width: clamp(320px, 65ch, 48rem);
    margin-inline: auto;
    padding: var(--space-xl) var(--space-lg) 0;
  }

  .ep-panel {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-rule);
  }

  .ep-panel:last-child {
    border-bottom: 1px solid var(--color-rule);
  }

  .hinge {
    border-left: 2px solid var(--color-accent-dim);
    padding-left: var(--space-lg);
    background: linear-gradient(90deg, rgba(196, 163, 90, 0.03) 0%, transparent 40%);
  }

  .ep-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .ep-id {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .ep-part {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hinge-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent-dim);
    letter-spacing: 0.06em;
  }

  .ep-synopsis {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .ep-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.7;
