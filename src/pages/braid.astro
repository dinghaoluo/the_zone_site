  P01: '--strand-slothrop', P02: '--strand-blicero', P03: '--strand-enzian', P04: '--strand-pokler',
  P05: '--strand-pointsman', P06: '--strand-counterforce', P07: '--strand-tchitcherine', P08: '--strand-film',
