                    ) : a.page ? (
                      <a class="sidenote-source sidenote-internal" href={`${base}${a.page}`}>{a.source}</a>
                    ) : (
                      <span class="sidenote-source">{a.source}</span>
                    )}
                  </div>
                ))}
              </aside>
            )}
