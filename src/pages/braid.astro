---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

import synopsesRaw from "../data/episode_synopses.json";
import unifiedData from "../data/phase_3a_unified_episode_data_public.json";
import quotesText from "../data/episode_anchor_quotes_APPROVED_PUBLIC.csv?raw";
import modalText from "../../public/data/step_3a/phase_3a_modal_intensity_matrix_public.csv?raw";
import recurrenceText from "../../public/data/step_3a/phase_3a_recurrence_intensity_matrix_public.csv?raw";
import plotlineArcsRaw from "../data/plotline_arc_descriptions.json";
import braidMatrixText from "../../public/data/step_3a/phase_3a_braid_intensity_matrix_public.csv?raw";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function parseCSV(raw: string) {
  const lines = raw.trim().split('\n');
  const headers = lines[0].split(',').map((h: string) => h.trim());
  const result = new Map();
  for (let i = 1; i < lines.length; i++) {
    const vals = lines[i].split(',');
    const eid = vals[0].trim();
    const row: any = {};
    for (let j = 1; j < headers.length; j++) row[headers[j]] = parseInt(vals[j], 10) || 0;
    result.set(eid, row);
  }
  return result;
}

function parseQuotesCSV(raw: string) {
  const result = new Map();
  for (const line of raw.trim().split('\n').slice(1)) {
    const fields: string[] = [];
    let cur = '';
    let inQ = false;
    for (let ci = 0; ci < line.length; ci++) {
      const ch = line[ci];
      if (ch === '"') { inQ = !inQ; }
      else if (ch === ',' && !inQ) { fields.push(cur); cur = ''; }
      else { cur += ch; }
    }
    fields.push(cur);
    const eid = fields[0]?.trim();
    const quote = fields[2]?.trim();
    const note = fields[7]?.trim();
    if (eid && quote) {
      if (!result.has(eid)) result.set(eid, []);
      result.get(eid)!.push({ quote, note: note || '' });
    }
  }
  return result;
}

const synopsesMap = new Map((synopsesRaw as any[]).map((s: any) => [s.episode_id, s.synopsis]));
const quotesMap = parseQuotesCSV(quotesText);
const modalMap = parseCSV(modalText);
const recurrenceMap = parseCSV(recurrenceText);

const PL: any = {
  P01: "Slothrop pursuit",
  P02: "Blicero triad",
  P03: "Schwarzkommando",
  P04: "Pökler / Imipolex",
  P05: "White Visitation",
  P06: "Counterforce",
  P07: "Tchitcherine",
  P08: "film-body-image",
};

const ML: any = {
  M01_science_control: "Science / Control",
  M02_pop_song_comedy: "Comedy / Song",
  M03_film_media_performance: "Film / Performance",
  M04_language_allusion: "Language / Allusion",
  M05_occult_divination: "Occult / Divination",
  M06_corporate_military_web: "Corporate-Military",
  M07_terminal_rocket_afterlife_descent: "Rocket / Terminal",
  M08_elect_preterite_theology: "Theology / Preterition",
  M09_sexuality_domination: "Sexuality / Domination",
  M10_waste_residue_body_grotesque: "Waste / Grotesque",
};

const RL: any = {
  species_extinction: "Species Extinction",
  colonial_genocide: "Colonial Genocide",
  holocaust_absence_or_adjacency: "Holocaust Adjacency",
  forced_labour_industrial_body_processing: "Forced Labour",
  postwar_technocratic_continuation: "Technocratic Continuation",
};

const HINGES = new Set(["1.01","1.04","1.14","2.01","3.01","3.11","3.22","3.29","4.05","4.12"]);

const HINGE_COMMENTARIES: Record<string, string> = {
  "1.01": "The novel opens by establishing its modal atmosphere before committing to any plotline. The screaming across the sky, Pirate’s dream of evacuation, the rocket’s physics as governing figure: these are not character introductions but threshold conditions. Every subsequent episode enters through what this one sets.",
  "1.04": "Slothrop’s sexual map coincides with V-2 impact sites, and from this coincidence the entire pursuit unfolds. Without the correlation that locks into place here, neither Pointsman’s programme nor Slothrop’s quest has an object. This is the braid’s first structural commitment: a body that desires and a body that is measured, discovered to be the same body.",
  "1.14": "Blicero, Katje, and Gottfried arrive fully formed in a single episode at maximum intensity. The fairy-tale script, the erotic command structure, the 00000 rocket as terminal parabola: all present from their first appearance. What this episode establishes, Part 4 will fulfil; it is the longest-range structural commitment in the novel.",
  "2.01": "The novel pivots from London’s institutional compression to the Riviera’s operational games. Slothrop converts from observed body to active pursuer; Pointsman’s apparatus converts from revelation to operational pursuit. The braid’s geometry shifts accordingly: from institutional density to pursuit-driven linearity.",
  "3.01": "Part 3’s immense middle section opens with Slothrop in maximum pursuit mode, crossing into the Zone. The stripped-back modal palette signals what is coming: the Zone dissolves the institutional frames that made pursuit legible. This episode launches the scattering it does not yet name.",
  "3.11": "One of the novel’s two most structurally dense episodes. Pökler arrives at Dora/Mittelwerk; individual engineering memory confronts the camp infrastructure it served. Four historical-recurrence registers activate simultaneously. Technical complicity is not adjacent to atrocity here; it is structurally identical with it. The novel’s ethical argument is most exposed at this node.",
  "3.22": "The Schwarzkommando revelation reaches full structural legibility. Colonial genocide and species extinction peak; the counter-text’s messianic search is articulated against the Final Zero’s self-extinction doctrine. The colonial-historical line achieves the weight it will carry into Part 4’s convergence.",
  "3.29": "Pökler’s plotline reaches its terminal mourning at maximum intensity. The Corporate City-state passage names the fantasy-template that Peenemünde and Mittelwerke realised: film as blueprint for technocratic complicity. The P04 line closes here; it will not appear in Part 4. Family loss has become inseparable from rocket production, and the complicity is irrevocable.",
  "4.05": "The 00000 launch: Gottfried sealed inside the Imipolex shroud, Blicero’s fairy-tale script fulfilled. ‘Of course it happened. Of course it didn’t happen.’ The sacrificial event is simultaneously fact and unintegratable; the novel’s central epistemological paradox enacted as structural climax. Everything that 1.14 established is delivered here.",
  "4.12": "The novel’s terminal episode, matched with 3.11 at peak structural density. Four plotlines converge: Blicero’s sacrifice, Enzian’s counter-text, Slothrop’s scattering, the film-body recurrence. The Orpheus Theatre fuses rocket, audience, and text into a single suspended instant. The descent never quite arrives. The braid holds.",
};

const HINGE_ATMOSPHERE: Record<string, string> = {
  "1.01": "Science and theology saturate the novel’s threshold simultaneously: Pavlovian conditioning and Puritan damnation as twin frameworks for the body under the rocket’s arc.",
  "1.04": "Science-control and sexuality-domination fuse at the correlation’s source. The body that desires and the body that is measured are discovered to be the same body.",
  "1.14": "Sexuality-domination and rocket-terminal at maximum, alongside species-extinction recurrence. The fairy-tale’s erotic cruelty scaled to planetary extermination logic.",
  "2.01": "Paranoia-conspiracy peaks as Slothrop senses the apparatus; corporate-military web at full density as the Riviera’s operational structure reveals itself. The shift from passive observation to active pursuit is also a shift from institutional to paranoid epistemology.",
  "3.01": "Corporate-military web in stripped form. The Zone’s dissolved geography requires no paranoia; power operates openly as debris, infrastructure, and ruin.",
  "3.11": "Forced labour, Holocaust adjacency, technocratic continuation, and colonial genocide activate simultaneously. The novel’s four historical debts concentrated in a single structural node. Film-body mode makes the camp visible as projected image.",
  "3.22": "Colonial genocide and species extinction at peak. The theological register sounds alongside them: the Schwarzkommando’s survival is framed as soteriological question, not merely political.",
  "3.29": "Corporate-military and film-body at maximum. The Metropolis fantasy as technocratic blueprint; cinema providing the ideology that industry enacts.",
  "4.05": "Rocket-terminal, sexuality-domination, and theology peak simultaneously. The launch is sacrificial consummation: the Oven’s warmth not as threat but as desired terminus.",
  "4.12": "Terminal-rocket-afterlife, corporate-military, and sexuality-domination at triple maximum. The Orpheus Theatre collapses all modal registers into one frozen instant; the novel ends not in resolution but in the permanent present tense of the approaching descent.",
};

const STRAND_LABELS = [
  { id: "P01", short: "Slothrop" },
  { id: "P02", short: "Blicero" },
  { id: "P03", short: "Enzian" },
  { id: "P04", short: "Pökler" },
  { id: "P05", short: "Pointsman" },
  { id: "P06", short: "Counterforce" },
  { id: "P07", short: "Tchitcherine" },
  { id: "P08", short: "Film/Body" },
];

/* ── Braid SVG geometry (build-time) ─────────────────────── */
const STRAND_COLORS: Record<string, string> = {
  P01: '#4A90D9', P02: '#D94A4A', P03: '#D9A84A', P04: '#8B6914',
  P05: '#6B8E6B', P06: '#7B68AE', P07: '#4A8B8B', P08: '#B85C8B',
};
const PLOTLINE_KEYS = ['P01','P02','P03','P04','P05','P06','P07','P08'];
const braidMatrix = parseCSV(braidMatrixText);
const EPISODE_IDS = Array.from(braidMatrix.keys());

const COL_W = 10;
const COL_GAP = 2;
const ROW_H = 11;
const LABEL_W = 30;
const PAD_TOP = 4;
const TOTAL_W = LABEL_W + EPISODE_IDS.length * (COL_W + COL_GAP);
const TOTAL_H = PAD_TOP + PLOTLINE_KEYS.length * ROW_H + 4;

const INTENSITY_OPACITY = [0.04, 0.22, 0.52, 1.0];
const INTENSITY_HEIGHT  = [2, 4, 6, 8];

const partBoundaries: number[] = [];
const PART_BOUNDS = [
  { after: '1.21', before: '2.01' },
  { after: '2.08', before: '3.01' },
  { after: '3.32', before: '4.01' },
];
for (const b of PART_BOUNDS) {
  const ai = EPISODE_IDS.indexOf(b.after);
  const bi = EPISODE_IDS.indexOf(b.before);
  if (ai >= 0 && bi >= 0) {
    partBoundaries.push(LABEL_W + ai * (COL_W + COL_GAP) + COL_W + COL_GAP / 2);
  }
}

interface BraidCell { x: number; y: number; w: number; h: number; opacity: number; fill: string; }
interface BraidCol { epId: string; x: number; isHinge: boolean; }

const braidCells: BraidCell[] = [];
const braidCols: BraidCol[] = [];

for (let ci = 0; ci < EPISODE_IDS.length; ci++) {
  const eid = EPISODE_IDS[ci];
  const row = braidMatrix.get(eid) || {};
  const x = LABEL_W + ci * (COL_W + COL_GAP);
  braidCols.push({ epId: eid, x, isHinge: HINGES.has(eid) });

  for (let ri = 0; ri < PLOTLINE_KEYS.length; ri++) {
    const pk = PLOTLINE_KEYS[ri];
    const val = row[pk] || 0;
    if (val === 0) continue;
    const cellH = INTENSITY_HEIGHT[val];
    const cy = PAD_TOP + ri * ROW_H + (ROW_H - cellH) / 2;
    braidCells.push({
      x: x + 1, y: cy, w: COL_W - 2, h: cellH,
      opacity: INTENSITY_OPACITY[val],
      fill: STRAND_COLORS[pk],
    });
  }
}

const plotlineArcs = (plotlineArcsRaw as any[]).map((a: any) => ({
  id: a.plotline_id,
  label: a.label,
  paragraphs: a.arc_description.split('\n\n'),
}));

type Ep = {
  id: string; part: number; isHinge: boolean;
  synopsis: string; strands: string;
  quotes: { quote: string; note: string }[];
  atmosphere: string; registers: string;
  hingeCommentary: string; hingeAtmosphere: string;
};

const episodes: Ep[] = unifiedData.map((u: any) => {
  const strands = Object.entries(u.plotlines || {})
    .filter(([_, v]: [string, any]) => (v as any).intensity >= 1)
    .map(([k, v]: [string, any]) => {
      const p = k.match(/^(P\d+)/)?.[1] || '';
      const fn = (v as any).function || 'active';
      return PL[p] + ' (' + fn + ')';
    });

  const mRow = modalMap.get(u.episode_id) || {};
  const modes = Object.entries(mRow)
    .filter(([_, v]) => (v as number) >= 2)
    .map(([k]) => ML[k] || k);

  const rRow = recurrenceMap.get(u.episode_id) || {};
  const regs = Object.entries(rRow)
    .filter(([_, v]) => (v as number) >= 1)
    .map(([k]) => RL[k] || k);

  return {
    id: u.episode_id,
    part: u.part,
    isHinge: HINGES.has(u.episode_id),
    synopsis: synopsesMap.get(u.episode_id) || '',
    strands: strands.length ? 'Active strands: ' + strands.join(', ') + '.' : '',
    quotes: quotesMap.get(u.episode_id) || [],
    atmosphere: modes.length ? 'Atmosphere: ' + modes.join(', ') + '.' : '',
    registers: regs.length ? 'Historical registers: ' + regs.join(', ') + '.' : '',
    hingeCommentary: HINGE_COMMENTARIES[u.episode_id] || '',
    hingeAtmosphere: HINGE_ATMOSPHERE[u.episode_id] || '',
  };
});

const p1 = episodes.filter((e: Ep) => e.part === 1);
const p2 = episodes.filter((e: Ep) => e.part === 2);
const p3a = episodes.filter((e: Ep) => e.part === 3 && parseInt(e.id.split('.')[1]) <= 10);
const p3b = episodes.filter((e: Ep) => e.part === 3 && parseInt(e.id.split('.')[1]) > 10);
const p4 = episodes.filter((e: Ep) => e.part === 4);
---

<Layout title="The Braid" description="Eight plotlines braiding through seventy-three episodes.">
  <Nav slot="nav" />

  <main class="braid">
    <section class="braid-intro">
      <p class="intro-text reveal">
        <em>Gravity&rsquo;s Rainbow</em> is a braid. Eight plotlines weave
        through seventy-three episodes across four parts, thickening where they
        govern structure, thinning where they yield: pursuit, sacrifice,
        counter-text, complicity, control, love, counter-line, and image. What
        follows is the novel read as that braid: each episode placed in
        sequence, its active strands named, its structural work made visible.
        Scroll as one would read.
      </p>
    </section>

    <div class="braid-scroll">
      <div class="braid-header" id="braid-header">
        <div class="braid-viz-wrap">
          <svg
            class="braid-viz"
            viewBox={`0 0 ${TOTAL_W} ${TOTAL_H}`}
            preserveAspectRatio="none"
            role="img"
            aria-label="Interactive braid: eight plotlines across seventy-three episodes"
          >
            {/* Strand labels (left edge) */}
            {PLOTLINE_KEYS.map((pk, ri) => (
              <text
                class="braid-label"
                x={LABEL_W - 3}
                y={PAD_TOP + ri * ROW_H + ROW_H / 2 + 1}
                text-anchor="end"
                fill={STRAND_COLORS[pk]}
                data-strand={pk}
                style="cursor:pointer"
              >
                {pk}
              </text>
            ))}

            {/* Hinge column highlights */}
            {braidCols.filter(c => c.isHinge).map(c => (
              <rect
                x={c.x}
                y={0}
                width={COL_W}
                height={TOTAL_H}
                fill="var(--color-accent)"
                opacity="0.06"
                rx="1"
              />
            ))}

            {/* Part boundary lines */}
            {partBoundaries.map(bx => (
              <line
                x1={bx} y1={0} x2={bx} y2={TOTAL_H}
                stroke="var(--color-text-dim)"
                stroke-width="0.8"
                stroke-dasharray="2,2"
                opacity="0.5"
              />
            ))}

            {/* Intensity cells */}
            {braidCells.map(cell => (
              <rect
                x={cell.x}
                y={cell.y}
                width={cell.w}
                height={cell.h}
                rx="1.5"
                fill={cell.fill}
                opacity={cell.opacity}
              />
            ))}

            {/* Clickable episode columns (transparent hit areas) */}
            {braidCols.map(c => (
              <rect
                class="braid-col-hit"
                x={c.x}
                y={0}
                width={COL_W}
                height={TOTAL_H}
                fill="transparent"
                data-ep={c.epId}
                style="cursor:pointer"
              />
            ))}

            {/* Scroll cursor (moves via JS) */}
            <rect
              class="braid-cursor"
              id="braid-cursor"
              x={LABEL_W}
              y={0}
              width={COL_W}
              height={TOTAL_H}
              fill="var(--color-accent)"
              opacity="0"
              rx="1"
            />
          </svg>
        </div>
        <nav class="strand-nav" aria-label="Plotline arcs">
          {STRAND_LABELS.map(s => (
            <button class="strand-btn" data-strand={s.id} type="button">
              {s.short}
            </button>
          ))}
        </nav>
        <div class="scroll-track">
          <span class="scroll-part-label" id="scroll-part-label">Part 1</span>
          <div class="scroll-bar">
            <div class="scroll-ticks">
              <span class="tick" style="left: 28.77%"></span>
              <span class="tick" style="left: 39.73%"></span>
              <span class="tick" style="left: 83.56%"></span>
            </div>
            <div class="scroll-fill" id="scroll-fill"></div>
          </div>
        </div>
      </div>

      <div class="reading-col">
        {p1.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="1">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.hingeCommentary && (
              <div class="hinge-commentary">
                <span class="hinge-commentary-label">Why this is a hinge</span>
                <p>{ep.hingeCommentary}</p>
              </div>
            )}
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.hingeAtmosphere ? (
              <p class="ep-meta hinge-atmosphere">{ep.hingeAtmosphere}</p>
            ) : (
              ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>
            )}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}

        <div class="part-transition reveal">
          <p>
            Part 1 ends with all eight strands established but unevenly
            weighted. Slothrop&rsquo;s pursuit and the White Visitation&rsquo;s control
            machinery dominate; Enzian&rsquo;s counter-text and Tchitcherine&rsquo;s
            Soviet line remain subterranean. Part 2 compresses to eight episodes
            and shifts the structural engine: Slothrop moves south into the
            Zone&rsquo;s threshold, Pointsman&rsquo;s apparatus strains toward its
            operational peak, and the Blicero triad receives its founding
            backstory. The braid tightens before the Zone blows it open.
          </p>
        </div>

        {p2.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="2">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.hingeCommentary && (
              <div class="hinge-commentary">
                <span class="hinge-commentary-label">Why this is a hinge</span>
                <p>{ep.hingeCommentary}</p>
              </div>
            )}
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.hingeAtmosphere ? (
              <p class="ep-meta hinge-atmosphere">{ep.hingeAtmosphere}</p>
            ) : (
              ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>
            )}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}

        <div class="part-transition reveal">
          <p>
            Part 3 is the explosion. Thirty-two episodes scatter across the
            Zone&rsquo;s dissolved geography: nearly half the novel. Slothrop
            fragments into aliases; Enzian&rsquo;s Schwarzkommando and
            Tchitcherine&rsquo;s counter-line claim structural weight they never had
            before; the film-body-image strand surges through the Anubis
            sequence; five plotlines compete for architectural command where
            Part 1 gave that authority to one or two. The braid does not
            loosen. It multiplies.
          </p>
        </div>

        <figure class="fig-plate reveal">
          <img
            src={`${base}/figures/step_3a/F03_modal_atmosphere.png`}
            alt="Modal atmosphere heatmap across seventy-three episodes"
            loading="lazy"
          />
          <figcaption class="plate-caption">
            The novel&rsquo;s episodes are not only driven by plotlines but saturated
            by modal atmospheres &mdash; registers of science, comedy, film, theology,
            sexuality, and violence that shift, peak, and recombine independently
            of the character-driven strands.
          </figcaption>
        </figure>

        {p3a.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="3">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.hingeCommentary && (
              <div class="hinge-commentary">
                <span class="hinge-commentary-label">Why this is a hinge</span>
                <p>{ep.hingeCommentary}</p>
              </div>
            )}
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.hingeAtmosphere ? (
              <p class="ep-meta hinge-atmosphere">{ep.hingeAtmosphere}</p>
            ) : (
              ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>
            )}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}

        <figure class="fig-plate reveal">
          <img
            src={`${base}/figures/step_3a/F04_historical_recurrence.png`}
            alt="Historical recurrence registers pulsing through specific structural nodes"
            loading="lazy"
          />
          <figcaption class="plate-caption">
            Historical violence is not uniformly distributed across the novel
            but pulses through specific structural nodes. Fifty-nine of
            seventy-three episodes carry no recurrence register at all.
          </figcaption>
        </figure>

        {p3b.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="3">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.hingeCommentary && (
              <div class="hinge-commentary">
                <span class="hinge-commentary-label">Why this is a hinge</span>
                <p>{ep.hingeCommentary}</p>
              </div>
            )}
            {ep.strands && <p class="ep-meta">{ep.strands}</p>}
            {ep.quotes.map((q: { quote: string; note: string }) => (
              <blockquote class="pull-quote">
                <p>{q.quote}</p>
                <cite>{q.note}</cite>
              </blockquote>
            ))}
            {ep.hingeAtmosphere ? (
              <p class="ep-meta hinge-atmosphere">{ep.hingeAtmosphere}</p>
            ) : (
              ep.atmosphere && <p class="ep-meta">{ep.atmosphere}</p>
            )}
            {ep.registers && <p class="ep-meta ep-registers">{ep.registers}</p>}
          </article>
        ))}

        <div class="part-transition reveal">
          <p>
            Twelve episodes. Everything that scattered in Part 3 now converges
            or extinguishes. Blicero&rsquo;s 00000 and Enzian&rsquo;s 00001 reach maximum
            intensity simultaneously. The Counterforce fails, then mourns.
            Slothrop scatters beyond recovery into theological trace. The
            Orpheus Theatre fuses rocket, film, and congregation into a single
            suspended instant.
          </p>
        </div>

        <figure class="fig-plate reveal">
          <img
            src={`${base}/figures/step_3a/F02_terminal_convergence.png`}
            alt="Part 4 convergence pattern showing plotlines collapsing toward the final episode"
            loading="lazy"
          />
          <figcaption class="plate-caption">
            Part 4&rsquo;s convergence pattern. Plotlines that ran separately for
            hundreds of pages now collapse toward the final episode.
          </figcaption>
        </figure>

        {p4.map((ep: Ep) => (
          <article class:list={['ep-panel', { hinge: ep.isHinge }]} id={`ep-${ep.id}`} data-part="4">
            <header class="ep-head">
              <span class="ep-id">{ep.id}</span>
              <span class="ep-part">Part {ep.part}</span>
              {ep.isHinge && <span class="hinge-label">Structural hinge</span>}
            </header>
            <p class="ep-synopsis">{ep.synopsis}</p>
            {ep.hingeCommentary && (
              <div class="hinge-commentary">
                <span class="hinge-commentary-label">Why this is a hinge</span>
                <p>{ep.hingeCommentary}</p>
              </div>
            )}
