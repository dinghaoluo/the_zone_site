type MetaRow = { time: string; location: string; focalisation: string };
const metaMap = new Map<string, MetaRow>();
{
  const metaLines = metadataText.replace(/^﻿/, '').trim().split('\n');
  const metaHeaders = metaLines[0].split(',');
  const iTime = metaHeaders.indexOf('diegetic_time_label');
  const iLoc = metaHeaders.indexOf('primary_location');
  const iFocal = metaHeaders.indexOf('focalisation_label');
  for (let i = 1; i < metaLines.length; i++) {
    const c = parseCsvLine(metaLines[i]);
    const eid = c[0]?.trim();
    if (!eid) continue;
    const rawTime = c[iTime]?.trim() || '';
    const rawLoc = c[iLoc]?.trim() || '';
    const rawFocal = c[iFocal]?.trim() || '';
    const time = TIME_LABELS[rawTime] || rawTime.replace(/-/g, ' ');
    const location = LOCATION_LABELS[rawLoc] || rawLoc.replace(/-/g, ' ');
    const focalisation = FOCAL_LABELS[rawFocal] || rawFocal.replace(/-/g, ' ');
    metaMap.set(eid, { time, location, focalisation });
  }
}

