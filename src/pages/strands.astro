---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
---

<Layout title="Strands" description="Narrative lines and motifs across Gravity's Rainbow.">
  <Nav slot="nav" />

  <Section>
    <div class="page-head reveal visible">
      <p class="eyebrow">04</p>
      <h1>Narrative lines and motifs</h1>
      <div class="page-lede">
        <p>
          Beyond individual characters and episodes, <em>Gravity's Rainbow</em>
          organises itself along narrative strands — recurring plotlines, thematic
          threads, and motif systems that weave through the text in overlapping
          patterns. Strand geometry describes how these lines enter, persist, hand
          off to one another, and fade.
        </p>
        <p>
          This section is still being consolidated from the underlying analysis.
          It will present strand continuity, handoff points between episodes, and
          motif intensity maps once the public-safe export contract for the 2H
          analytical layer is finalised.
        </p>
      </div>
    </div>
  </Section>

  <Footer slot="footer" />
</Layout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin-bottom: var(--space-xl);
  }

  .page-lede {
    max-width: var(--max-width-narrow);
  }

  .page-lede p {
    font-size: var(--text-base);
    line-height: 1.85;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
</style>
